{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4321",
      "startServerReadyPattern": "Local",
      "startServerReadyTimeout": 120000,
      "numberOfRuns": 1,
      "url": [
        "http://127.0.0.1:4321/",
        "http://127.0.0.1:4321/about",
        "http://127.0.0.1:4321/how-we-help",
        "http://127.0.0.1:4321/impact",
        "http://127.0.0.1:4321/get-involved",
        "http://127.0.0.1:4321/contact",
        "http://127.0.0.1:4321/donate"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 1 }],
        "categories:best-practices": ["error", { "minScore": 1 }],
        "categories:seo": ["error", { "minScore": 1 }],
        "categories:performance": ["warn", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
