---
interface Props {
  items: string[];
  size?: "sm" | "base";
  columns?: 1 | 2;
}

const { items, size = "base", columns = 1 } = Astro.props;

const textClass = size === "sm" ? "text-sm" : "text-base";
const columnsClass = columns === 2 ? "sm:columns-2" : "";
---

<ul class={`mt-4 space-y-2 ${columnsClass}`}>
  {items.map((item) => (
    <li class={`flex items-start gap-2 ${textClass} leading-7 text-text-subtle`}>
      <span
        class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-secondary"
        aria-hidden="true"
      ></span>
      <span>{item}</span>
    </li>
  ))}
</ul>
