---
import Button from "./Button.astro";

interface Props {
  heading: string;
  body?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  variant?: "fill" | "outline" | "bare";
}

const {
  heading,
  body,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  variant = "fill",
} = Astro.props;

const sectionClass =
  variant === "outline"
    ? "rounded-lg border border-border-default px-6 py-8 text-center md:px-8 md:py-10"
    : variant === "bare"
    ? "py-8 text-center md:py-10"
    : "rounded-lg bg-surface-subtle px-6 py-8 text-center md:px-8 md:py-10";
---

<section class={sectionClass}>
  <h2 class="text-xl font-semibold text-text-default">{heading}</h2>
  {body && (
    <p class="mx-auto mt-3 max-w-2xl text-base leading-7 text-text-subtle">{body}</p>
  )}
  <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
    <Button href={primaryHref} variant="primary">{primaryLabel}</Button>
    {secondaryLabel && secondaryHref && (
      <Button href={secondaryHref} variant="secondary">{secondaryLabel}</Button>
    )}
  </div>
</section>
