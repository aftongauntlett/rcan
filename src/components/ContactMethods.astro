---
import ContactInfoCard from "./ContactInfoCard.astro";
---

<div class="lg:col-span-2">
  <div class="space-y-4">
    <p class="text-base leading-7 text-text-subtle">
      Whether you're a congregation looking to get involved, an individual with a question, or an
      organization exploring partnership, we'd love to hear from you.
    </p>
    <p class="text-base leading-7 text-text-subtle">
      RCAN welcomes partnership from communities committed to practical, dignity-centered reentry
      support. We read every message and do our best to reply quickly, usually by email.
    </p>
    <p class="text-base leading-7 text-text-subtle">
      Not sure where to start? Just say hello — we'll help point you in the right direction.
    </p>
  </div>

  <div class="mt-8 space-y-5" aria-labelledby="contact-methods-heading">
    <h2 id="contact-methods-heading" class="sr-only">Contact information</h2>

    <ContactInfoCard
      icon="mail"
      href="mailto:dcrcan2018@gmail.com"
      copyValue="dcrcan2018@gmail.com"
      copyLabel="Copy email address"
      feedbackId="email-copy-feedback"
    >
      dcrcan2018@gmail.com
    </ContactInfoCard>

    <ContactInfoCard
      icon="phone"
      href="tel:+12403937246"
      copyValue="(240) 393-7246"
      copyLabel="Copy phone number"
      feedbackId="phone-copy-feedback"
    >
      (240) 393-7246
    </ContactInfoCard>

    <ContactInfoCard
      icon="map-pin"
      copyValue="5109 Nannie Helen Burroughs Ave. NE, Washington, DC 20019"
      copyLabel="Copy mailing address"
      feedbackId="address-copy-feedback"
    >
      5109 Nannie Helen Burroughs Ave. NE<br />Washington, DC 20019
    </ContactInfoCard>
  </div>
  <p class="mt-3 text-sm leading-6 text-text-subtle">
    Mailing address only — for letters and correspondence. Please do not visit in person.
  </p>
</div>
