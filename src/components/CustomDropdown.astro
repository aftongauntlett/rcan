---
import type { HTMLAttributes } from "astro/types";
import Icon from "./Icon.astro";
import { resolveInitialOption, type DropdownOption } from "../utils/dropdown";

interface Props extends Omit<HTMLAttributes<"div">, "class"> {
  id: string;
  name: string;
  labelledBy: string;
  options: DropdownOption[];
  defaultValue?: string;
  required?: boolean;
  disabled?: boolean;
  class?: string;
  dataFsField?: boolean;
}

const {
  id,
  name,
  labelledBy,
  options,
  defaultValue,
  required = false,
  disabled = false,
  class: className = "",
  dataFsField = true,
  ...rest
} = Astro.props as Props;

const selectedOption = resolveInitialOption(options, defaultValue);
const menuId = `${id}-menu`;
const triggerId = `${id}-trigger`;
---

<div class={`relative ${className}`} data-custom-dropdown data-dropdown-open="false" {...rest}>
  <input
    type="hidden"
    name={name}
    value={selectedOption.value}
    required={required}
    data-dropdown-input
    data-fs-field={dataFsField ? "" : undefined}
  />

  <button
    id={triggerId}
    type="button"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls={menuId}
    aria-labelledby={`${labelledBy} ${id}-value`}
    disabled={disabled}
    data-dropdown-trigger
    class="flex w-full items-center justify-between gap-3 rounded-md border border-border-default bg-surface-default px-3 py-2 text-left text-base text-text-default shadow-sm transition-colors duration-base hover:border-border-strong hover:bg-surface-subtle disabled:cursor-not-allowed disabled:opacity-60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default"
  >
    <span id={`${id}-value`} data-dropdown-label class="truncate">
      {selectedOption.label}
    </span>
    <Icon
      name="chevron-right"
      size="sm"
      aria-hidden="true"
      data-dropdown-chevron
      class="rotate-90 text-text-subtle transition-transform duration-base"
    />
  </button>

  <div
    id={menuId}
    role="menu"
    aria-labelledby={labelledBy}
    tabindex={-1}
    hidden
    data-dropdown-menu
    class="absolute z-20 mt-2 max-h-64 w-full overflow-auto rounded-md border border-border-default bg-surface-default shadow-md"
  >
    <ul role="none" class="py-1">
      {
        options.map((option) => {
          const isSelected = option.value === selectedOption.value;

          return (
            <li role="none">
              <button
                type="button"
                role="menuitemradio"
                aria-checked={isSelected ? "true" : "false"}
                aria-disabled={option.disabled ? "true" : undefined}
                disabled={option.disabled}
                tabindex={-1}
                data-dropdown-option
                data-value={option.value}
                data-label={option.label}
                class={`flex w-full items-center justify-between gap-3 px-3 py-2 text-left text-base transition-colors duration-fast focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-inset disabled:cursor-not-allowed disabled:opacity-60 ${
                  isSelected
                    ? "bg-surface-subtle text-brand-primary"
                    : "text-text-default hover:bg-surface-subtle"
                }`}
              >
                <span>{option.label}</span>
                <Icon
                  name="check"
                  size="sm"
                  aria-hidden="true"
                  data-dropdown-check
                  class={`text-brand-primary transition-opacity duration-fast ${
                    isSelected ? "opacity-100" : "opacity-0"
                  }`}
                />
              </button>
            </li>
          );
        })
      }
    </ul>
  </div>
</div>

<script>
  import { bootstrapCustomDropdowns } from "../utils/dropdownClient";

  bootstrapCustomDropdowns();
</script>
