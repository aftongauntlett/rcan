---
import { Image } from "astro:assets";
import Link from "./Link.astro";
import Icon from "./Icon.astro";
import logo from "../assets/rcan-logo-lockup-tagline.png";

const year = new Date().getFullYear();
const footerNavItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/how-we-help", label: "How We Help" },
  { href: "/who-we-are", label: "Who We Are" },
  { href: "/impact", label: "Impact" },
  { href: "/get-involved", label: "Get Involved" },
  { href: "/contact", label: "Contact" },
  { href: "/donate", label: "Donate" },
];
---

<footer class="bg-surface-default">
  <div class="mx-auto w-full max-w-7xl border-t border-border-default px-4 py-5">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-[180px_1fr_180px] md:items-center">
      <!-- Logo -->
      <div class="flex justify-center md:justify-start">
        <Image
          src={logo}
          alt="Returning Citizens Assistance Network — Helping Your Neighbors Come Home"
          width={272}
          height={166}
          class="h-auto w-44"
        />
      </div>

      <!-- Nav + copyright -->
      <div class="flex flex-col items-center gap-3 text-center">
        <nav aria-label="Footer" class="w-full">
          <ul class="flex flex-wrap items-center justify-center gap-x-1 gap-y-1 text-sm">
            {
              footerNavItems.map((item) => (
                <li>
                  <Link
                    href={item.href}
                    variant="subtle"
                    showExternalIndicator={false}
                    class="rounded-md px-2 py-1 text-text-subtle hover:text-text-default hover:underline hover:decoration-brand-secondary hover:underline-offset-4"
                  >
                    {item.label}
                  </Link>
                </li>
              ))
            }
          </ul>
        </nav>

        <hr class="mb-1 w-16 border-t border-border-default" />

        <div class="flex flex-col items-center gap-0.5">
          <p class="text-center text-[11px] text-text-subtle">
            Copyright {year} Returning Citizens Assistance Network · RCAN is a 501(c)(3) organization
            and donations are tax deductible.
          </p>
          <p class="text-center text-[11px] text-text-subtle">
            Built by{" "}
            <a
              href="https://www.prettyprettyprettygood.org/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="prettyprettyprettygood (opens in a new tab)"
              class="font-medium text-text-subtle hover:text-text-default hover:underline hover:decoration-brand-secondary hover:underline-offset-4"
            >
              prettyprettyprettygood
            </a>
          </p>
        </div>
      </div>

      <!-- Back to top -->
      <div class="flex justify-center md:justify-end">
        <button
          type="button"
          data-back-to-top
          aria-label="Back to top"
          class="inline-flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full border border-border-default bg-surface-default text-text-subtle hover:border-brand-secondary hover:bg-brand-secondary/10 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default"
        >
          <Icon name="arrow-up-right" size="sm" class="-rotate-45" aria-hidden="true" />
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const scrollBehavior = prefersReducedMotion ? "auto" : "smooth";

  document.querySelectorAll("[data-back-to-top]").forEach((control) => {
    control.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: scrollBehavior });
    });
  });
</script>
