---
import Link from "./Link.astro";

// New shared site-chrome component for BaseLayout; no reusable header existed in src/components.
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/how-we-help", label: "How We Help" },
  { href: "/get-involved", label: "Get Involved" },
  { href: "/donate", label: "Donate" },
  { href: "/contact", label: "Contact" },
];
---

<header class="border-b border-border-default bg-surface-default">
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4">
    <Link href="/" class="text-lg font-semibold text-text-default no-underline hover:text-brand-primary">
      RCAN
    </Link>

    <nav aria-label="Primary" class="flex items-center">
      <ul class="flex flex-wrap items-center justify-end gap-2 text-sm">
        {
          navItems.map((item) => (
            <li>
              <Link
                href={item.href}
                class="rounded-md px-3 py-2 no-underline text-text-subtle hover:bg-surface-subtle hover:text-text-default"
              >
                {item.label}
              </Link>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>