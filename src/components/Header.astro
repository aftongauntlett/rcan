---
import Link from "./Link.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import logo from "../assets/rcan_logo_final.svg?url";

// New shared site-chrome component for BaseLayout; no reusable header existed in src/components.
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/how-we-help", label: "How We Help" },
  { href: "/impact", label: "Impact" },
  { href: "/get-involved", label: "Get Involved" },
  { href: "/contact", label: "Contact" },
];

const normalizePath = (path: string) => (path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);
const isDonateActive = currentPath === "/donate";
---

<header id="top" class="sticky top-0 z-50 border-b border-border-default bg-surface-default">
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-3">
    <Link href="/" variant="subtle" class="rounded-md" aria-label="Returning Citizens Assistance Network home">
      <img
        src={logo}
        alt="RCAN"
        class="h-12 w-auto md:h-14"
        loading="eager"
      />
    </Link>

    <nav aria-label="Primary" class="flex flex-1 items-center justify-end gap-2">
      <button
        type="button"
        data-mobile-nav-open
        aria-controls="mobile-nav-dialog"
        aria-haspopup="dialog"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border-default bg-surface-default text-text-subtle hover:border-border-strong hover:text-text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 md:hidden"
      >
        <span class="sr-only">Open navigation menu</span>
        <Icon name="menu" aria-hidden="true" />
      </button>

      <ul class="hidden flex-wrap items-center justify-end gap-1 text-sm md:flex">
        {
          navItems.map((item) => {
            const isActive = currentPath === normalizePath(item.href);
            return (
              <li>
                <Link
                  href={item.href}
                  variant="subtle"
                  aria-current={isActive ? "page" : undefined}
                  class={`rounded-md px-3 py-2 ${
                    isActive
                      ? "bg-surface-subtle text-text-default"
                      : "text-text-subtle hover:bg-neutral-200 hover:text-text-default"
                  }`}
                >
                  {item.label}
                </Link>
              </li>
            );
          })
        }
      </ul>

      <div class="ml-1 md:ml-3">
        <Button
          href="/donate"
          size="sm"
          variant={isDonateActive ? "secondary" : "primary"}
          aria-current={isDonateActive ? "page" : undefined}
          class={isDonateActive ? "border-border-default bg-surface-subtle text-text-default" : ""}
        >
          Donate
        </Button>
      </div>
    </nav>
  </div>

  <dialog
    id="mobile-nav-dialog"
    data-mobile-nav-dialog
    aria-label="Mobile navigation"
    class="fixed inset-y-0 right-0 m-0 h-full w-full max-w-sm border-0 bg-transparent p-0 text-text-default backdrop:bg-surface-invert/70 md:hidden"
  >
    <div class="ml-auto flex h-full w-full max-w-sm flex-col border-l border-border-default bg-surface-default shadow-lg">
      <div class="flex items-center justify-between border-b border-border-default px-4 py-3">
        <p class="text-sm font-semibold uppercase tracking-wide text-text-subtle">Menu</p>
        <button
          type="button"
          data-mobile-nav-close
          class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border-default bg-surface-default text-text-subtle hover:border-border-strong hover:text-text-default focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
        >
          <span class="sr-only">Close navigation menu</span>
          <Icon name="x" aria-hidden="true" />
        </button>
      </div>

      <nav aria-label="Mobile Primary" class="flex-1 overflow-y-auto px-4 py-4">
        <ul class="space-y-1">
          {
            navItems.map((item) => {
              const isActive = currentPath === normalizePath(item.href);
              return (
                <li>
                  <Link
                    href={item.href}
                    variant="subtle"
                    aria-current={isActive ? "page" : undefined}
                    class={`w-full rounded-md px-3 py-2 text-base ${
                      isActive
                        ? "bg-surface-subtle text-text-default"
                        : "text-text-subtle hover:bg-neutral-200 hover:text-text-default"
                    }`}
                  >
                    {item.label}
                  </Link>
                </li>
              );
            })
          }
        </ul>

        <div class="mt-5 border-t border-border-default pt-5">
          <Button href="/donate" variant="primary" size="md" class="w-full justify-center">Donate</Button>
        </div>
      </nav>
    </div>
  </dialog>
</header>

<script>
  import { initMobileNavDialog } from "../utils/mobileNav";

  initMobileNavDialog();
  document.addEventListener("astro:page-load", () => initMobileNavDialog());
</script>