---
import Icon from "./Icon.astro";
import Button from "./Button.astro";

type IconName =
  | "arrow-right"
  | "arrow-up-right"
  | "book-open"
  | "check"
  | "chevron-right"
  | "dollar-sign"
  | "external-link"
  | "globe"
  | "home"
  | "heart"
  | "info"
  | "mail"
  | "map-pin"
  | "menu"
  | "phone"
  | "user"
  | "users"
  | "x";

interface IconSupportListItem {
  icon: IconName;
  text: string;
  label?: string;
  cta?: { label: string; href: string };
}

interface Props {
  items: readonly IconSupportListItem[];
  ariaLabel: string;
  columns?: 1 | 2;
  ordered?: boolean;
  class?: string;
  inlineCta?: boolean;
  ctaButton?: boolean;
}

const {
  items,
  ariaLabel,
  columns = 2,
  ordered = false,
  class: className = "",
  inlineCta = false,
  ctaButton = false,
} = Astro.props;

const ListTag = ordered ? "ol" : "ul";
const columnsClass = columns === 1 ? "grid-cols-1" : "grid-cols-1 sm:grid-cols-2";
---

<ListTag class={`mt-6 grid ${columnsClass} gap-x-12 gap-y-2 ${className}`} aria-label={ariaLabel}>
  {
    items.map((item) => (
      <li class={`group flex ${(item.label && !inlineCta) ? "items-start" : "items-center"} gap-3 rounded-md px-3 py-2 text-base leading-7 text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:bg-surface-default`}>
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-accent text-surface-default motion-safe:transition-colors motion-safe:duration-200 group-hover:bg-brand-secondary" aria-hidden="true">
          <Icon name={item.icon} size="sm" aria-hidden="true" />
        </span>
        <div class={ctaButton ? "flex flex-1 flex-col min-w-0" : inlineCta ? "flex-1 min-w-0" : "flex min-h-14 flex-1 flex-col justify-center"}>
          {item.label && <span class="whitespace-nowrap text-sm font-semibold uppercase tracking-wide text-brand-secondary">{item.label}</span>}
          <span class={item.label ? "mt-0.5" : ""}>{item.text}</span>
          {item.cta && !inlineCta && !ctaButton && (
            <a
              href={item.cta.href}
              class="mt-2 inline-flex items-center gap-1 self-start text-sm font-semibold text-brand-secondary underline-offset-4 hover:underline focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-primary"
            >
              {item.cta.label} <Icon name="arrow-right" size="sm" aria-hidden="true" />
            </a>
          )}
        </div>
        {item.cta && inlineCta && (
          <a
            href={item.cta.href}
            class="ml-auto shrink-0 inline-flex items-center gap-1 text-sm font-semibold text-brand-secondary underline-offset-4 hover:underline focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-primary"
          >
            {item.cta.label} <Icon name="arrow-right" size="sm" aria-hidden="true" />
          </a>
        )}
        {item.cta && ctaButton && (
          <Button href={item.cta.href} variant="secondary" size="sm" class="shrink-0 min-w-24">{item.cta.label}</Button>
        )}
      </li>
    ))
  }
</ListTag>