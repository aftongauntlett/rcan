---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Icon from "./Icon.astro";

interface CarouselSlide {
  src: ImageMetadata;
  alt: string;
  class?: string;
  quality?: number;
}

interface Props {
  id: string;
  ariaLabel: string;
  slides: readonly CarouselSlide[];
  frameClass?: string;
}

const { id, ariaLabel, slides, frameClass = "shadow-sm" } = Astro.props as Props;
---

<div class="flex h-full flex-col" data-carousel aria-label={ariaLabel}>
  <div id={id} class={`group relative h-96 overflow-hidden rounded-lg md:h-112 lg:h-full ${frameClass}`}>
    {
      slides.map((slide, index) => (
        <figure
          data-carousel-slide
          class={`absolute inset-0 h-full motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out ${
            index === 0 ? "opacity-100" : "opacity-0 pointer-events-none"
          }`}
        >
          <Image
            src={slide.src}
            class={`h-full w-full ${slide.class ?? "object-cover"}`}
            alt={slide.alt}
            width={600}
            widths={[320, 480, 600]}
            sizes="(min-width: 1024px) 32vw, 100vw"
            format="webp"
            quality={slide.quality ?? 65}
            loading="lazy"
          />
        </figure>
      ))
    }
    <div class="absolute inset-x-0 bottom-0 z-10 border-t border-neutral-200/40 bg-surface-invert/90 px-4 py-3">
      <div class="flex items-center justify-between gap-3">
        <button
          type="button"
          data-carousel-prev
          aria-label="Previous photo"
          aria-controls={id}
          class="inline-flex cursor-pointer items-center gap-2 rounded px-3 py-1.5 text-sm font-medium text-text-invert transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary disabled:cursor-not-allowed disabled:opacity-50"
        >
          <Icon name="chevron-right" size="sm" class="rotate-180" aria-hidden="true" />
          <span>Prev</span>
        </button>
        <p class="text-sm font-medium text-neutral-100" data-carousel-status aria-live="polite">Photo 1 of {slides.length}</p>
        <button
          type="button"
          data-carousel-next
          aria-label="Next photo"
          aria-controls={id}
          class="inline-flex cursor-pointer items-center gap-2 rounded px-3 py-1.5 text-sm font-medium text-text-invert transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary disabled:cursor-not-allowed disabled:opacity-50"
        >
          <span>Next</span>
          <Icon name="chevron-right" size="sm" aria-hidden="true" />
        </button>
      </div>
    </div>
  </div>
</div>
