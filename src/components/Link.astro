---
import type { HTMLAttributes } from "astro/types";

type LinkVariant = "inline" | "subtle";

interface Props extends Omit<HTMLAttributes<"a">, "href" | "class" | "rel"> {
  href: string;
  class?: string;
  rel?: string;
  showExternalIndicator?: boolean;
  externalIndicatorLabel?: string;
  variant?: LinkVariant;
}

const {
  href,
  class: className = "",
  rel,
  showExternalIndicator = true,
  externalIndicatorLabel = "External link",
  variant = "inline",
  ...rest
} = Astro.props as Props;

const isExternal = /^(?:[a-z][a-z0-9+.-]*:|\/\/)/i.test(href);

const relValues = new Set((rel ?? "").split(" ").filter(Boolean));
if (isExternal) {
  relValues.add("noopener");
  relValues.add("noreferrer");
}
const resolvedRel = relValues.size > 0 ? Array.from(relValues).join(" ") : undefined;

const baseClasses =
  "inline-flex items-center gap-1 font-medium transition-colors duration-base focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default";

const variantClasses: Record<LinkVariant, string> = {
  inline:
    "text-text-link underline decoration-brand-primary underline-offset-2 hover:text-brand-secondary",
  subtle: "text-text-default no-underline hover:text-brand-primary",
};
---

<a
  href={href}
  rel={resolvedRel}
  class={`${baseClasses} ${variantClasses[variant]} ${className}`}
  {...rest}
>
  <slot />
  {
    isExternal && showExternalIndicator && (
      <span aria-hidden="true" class="text-sm text-text-subtle">
        External
      </span>
    )
  }
  {isExternal && showExternalIndicator && <span class="sr-only">{externalIndicatorLabel}</span>}
</a>
