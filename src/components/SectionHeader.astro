---
import type { HTMLAttributes } from "astro/types";

type HeadingLevel = 1 | 2 | 3 | 4;

interface Props extends Omit<HTMLAttributes<"header">, "class"> {
  heading: string;
  eyebrow?: string;
  tagline?: string;
  subheading?: string;
  level?: HeadingLevel;
  class?: string;
  headingClass?: string;
  divider?: boolean;
}

const {
  heading,
  eyebrow,
  tagline,
  subheading,
  level = 2,
  class: className = "",
  headingClass,
  divider = false,
  ...rest
} = Astro.props as Props;

const HeadingTag = `h${level}` as "h1" | "h2" | "h3" | "h4";

const headingSizes: Record<HeadingLevel, string> = {
  1: "text-4xl",
  2: "text-3xl",
  3: "text-2xl",
  4: "text-xl",
};

const headingColorAndSize = headingClass ?? `${headingSizes[level]} text-text-default`;
---

<header class={`space-y-5 ${className}`} {...rest}>
  {eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">{eyebrow}</p>}

  <div class="space-y-1">
    <HeadingTag class={`font-serif font-semibold leading-tight ${headingColorAndSize}`}>
      {heading}
    </HeadingTag>

    {tagline && <p class="font-serif text-lg italic leading-snug text-text-subtle md:text-xl">{tagline}</p>}
  </div>

  {divider && <div class="h-1.5 w-20 rounded-full bg-brand-secondary" aria-hidden="true"></div>}

  {subheading && <p class="text-base text-text-subtle">{subheading}</p>}
</header>