---
import SkipLink from "../components/SkipLink.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import defaultOgImage from "../assets/rcan-logo-lockup-tagline.png";
import "../styles/global.css";
import "@fontsource/manrope/latin-400.css";
import "@fontsource/manrope/latin-700.css";
import "@fontsource/quicksand/latin-600.css";
import "@fontsource/quicksand/latin-700.css";
import "@fontsource/caveat/latin-600.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = defaultOgImage.src } = Astro.props as Props;

const resolvedSite = Astro.site ?? new URL("https://rcan.example");
const canonicalUrl = new URL(Astro.url.pathname, resolvedSite).toString();

const resolvedOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, resolvedSite).toString();
---

<!doctype html>
<html lang="en" class="h-full bg-surface-default text-text-default">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body class="flex min-h-full flex-col bg-surface-default font-sans text-text-default antialiased">
    <SkipLink href="#main-content" />
    <Header />
    <main
      id="main-content"
      class="mx-auto w-full max-w-7xl flex-1 px-4 pt-4 pb-10 md:px-6 space-y-12 md:space-y-16"
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
