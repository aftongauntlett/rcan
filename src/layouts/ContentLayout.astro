---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props as Props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <section aria-label="Page content" class="mx-auto w-full max-w-4xl px-4 py-8">
    <article class="prose prose-neutral max-w-none text-text-default">
      <slot />
    </article>
  </section>
</BaseLayout>
