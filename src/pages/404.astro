---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";

const pageTitle = "Page Not Found | RCAN";
const pageDescription =
  "The page you are looking for could not be found. Use RCAN navigation links to continue browsing.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section
    class="mx-auto max-w-3xl rounded-lg border border-border-default bg-surface-subtle px-6 py-10 text-center md:px-8 md:py-12"
    aria-labelledby="not-found-heading"
  >
    <PageHeader
      id="not-found-heading"
      eyebrow="404"
      heading="We could not find that page"
      subheading="The link may be outdated, or the page may have moved. You can return to the homepage, explore how RCAN helps, or contact us for assistance."
    />

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <Button href="/" variant="primary" size="md">Go to Home</Button>
      <Button href="/how-we-help" variant="secondary" size="md">How We Help</Button>
      <Button href="/contact" variant="secondary" size="md">Contact RCAN</Button>
    </div>
  </section>
</BaseLayout>
