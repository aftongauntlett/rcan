---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Icon from "../components/Icon.astro";
import CTABlock from "../components/CTABlock.astro";
import holdingHandsImage from "../assets/holding-hands.jpg";
import communityHeroImage from "../assets/community-is-strength.jpg";
import handShakeLogoImage from "../assets/hand-shake-logo.jpg";
import { Calendar } from "@lucide/astro";

const pageTitle = "About RCAN | Returning Citizens Assistance Network";
const pageDescription =
  "Read about RCAN's mission, history, and community-centered approach to supporting successful re-entry.";

const values = [
  "Dignity-first support for people returning to society",
  "Rapid response to urgent short-term needs",
  "Congregation-led coordination and care",
  "Practical pathways toward housing, stability, and work",
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="border-b border-border-default pb-10 pt-6 md:pt-8">
    <SectionHeader
      level={1}
      heading="Community networks changing reentry outcomes"
      subheading="RCAN responds to requests from the DC Public Defender Service and connects congregations with practical ways to support returning citizens."
    />
    <p class="mt-6 text-base leading-7 text-text-subtle">
      In 2018, New York Avenue Presbyterian Church and Metropolitan AME Church worked with the
      Public Defender Service of the District of Columbia to establish the Returning Citizens
      Assistance Network (RCAN). This informal network is composed of twenty congregations that
      agree to assist returning citizens and others in the criminal justice system who face
      specific short-term needs.
    </p>
  </section>

  <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="history-heading">
    <div class="grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-center">
      <div>
        <h2 id="history-heading" class="section-title text-text-subtle">How RCAN came together</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border-default bg-surface-default px-3 py-1 text-sm font-medium text-text-default">
            <Calendar size={14} aria-hidden="true" class="shrink-0 text-brand-secondary" />
            Founded 2018
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border-default bg-surface-default px-3 py-1 text-sm font-medium text-text-default">
            <Icon name="users" size="sm" class="text-brand-secondary" aria-hidden="true" />
            22 congregations
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border-default bg-surface-default px-3 py-1 text-sm font-medium text-text-default">
            <Icon name="map-pin" size="sm" class="text-brand-secondary" aria-hidden="true" />
            DC, Maryland &amp; Virginia
          </span>
        </div>
        <p class="mt-4 max-w-3xl text-base leading-7 text-text-subtle">
          Inspired by Bryan Stevenson's call to get proximate to the poor and the incarcerated, a
          partnership formed with the DC Public Defender Service to respond to practical reentry needs.
          In 2018, NYAPC and Metropolitan AME Church launched RCAN as a congregation network. It has
          since grown to twenty congregations coordinating direct responses to individual requests —
          making practical help available quickly and without bureaucracy.
        </p>
        <p class="mt-4 max-w-3xl text-base leading-7 text-text-subtle">
          RCAN generally engages with one or two cases each week, with that number growing as more
          congregations and individuals join. RCAN shares information about each case with the full
          network; each congregation then determines for itself whether it is able to help with a
          particular case.
        </p>
      </div>
      <figure class="hidden overflow-hidden rounded-lg shadow-md lg:block">
        <Image
          src={communityHeroImage}
          alt="Community members gather together, showing the collective strength and care that defines RCAN's network."
          class="h-full w-full object-cover"
          width={600}
          widths={[400, 600]}
          sizes="40vw"
          format="webp"
          quality={65}
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <section class="py-10" aria-labelledby="rcan-fund-heading">
    <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-start">
      <figure class="overflow-hidden rounded-lg shadow-md">
        <Image
          src={holdingHandsImage}
          class="w-full object-cover"
          alt="Two people holding hands, representing the mutual support at the heart of RCAN's mission."
          width={480}
          widths={[320, 480]}
          sizes="(min-width: 1024px) 33vw, 100vw"
          format="webp"
          quality={60}
          loading="lazy"
        />
      </figure>
      <div>
        <h2 id="rcan-fund-heading" class="section-title text-text-subtle">The RCAN Fund</h2>
        <p class="mt-4 text-base leading-7 text-text-subtle">
          The RCAN Fund was established through New York Avenue Presbyterian Church in January 2021
          to facilitate online donations supporting client requests from the DC PDS. In 2025,
          contributions helped 361 clients — including 10 families (51 adults and children) who
          received holiday gift baskets, and 36 incarcerated clients without external support who
          each received $50 in commissary funds.
        </p>
        <p class="mt-3 text-base leading-7 text-text-subtle">
          Each December since 2020, RCAN has prepared holiday gift baskets for PDS-selected families
          and individuals. In 2025, ten families — 51 adults and children — received gifts by Christmas.
        </p>
        <p class="mt-3 text-base leading-7 text-text-subtle">
          To donate online, visit <a href="/donate" class="text-text-link underline underline-offset-2 hover:text-brand-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">RCAN's donate page</a>. To give by mail, send contributions to New York Avenue Presbyterian
          Church at Placeholder Mailing Address, Washington, DC 00000.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Shared Identity -->
  <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="identity-heading">
    <div class="grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-start">
      <div>
        <h2 id="identity-heading" class="section-title text-text-subtle">Our shared identity</h2>
        <p class="mt-4 text-base leading-7 text-text-subtle">
          RCAN is rooted in the conviction that practical support and faithful community can reshape reentry outcomes.
          Twenty-two congregations across DC, Maryland, and Virginia share this commitment — different in tradition,
          united in purpose.
        </p>
        <ul class="mt-6 space-y-3" aria-label="RCAN core values">
          {
            values.map((item) => (
              <li class="flex items-start gap-3 text-base leading-7 text-text-subtle">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-secondary" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="flex flex-col items-center gap-5">
        <figure class="w-full max-w-56 overflow-hidden rounded-lg shadow-md">
          <Image
            src={handShakeLogoImage}
            alt="Two hands clasped in a handshake — the RCAN network mark."
            class="w-full object-cover"
            width={282}
            widths={[141, 282]}
            sizes="14rem"
            format="webp"
            quality={70}
            loading="lazy"
          />
        </figure>
        <blockquote class="pr-5 text-right text-base italic leading-8 text-text-default">
          "Act justly, love mercy, and walk humbly."
        </blockquote>
        <p class="-mt-3 pr-5 text-right text-sm text-text-subtle">— Micah 6:8</p>
      </div>
    </div>
  </section>

  <CTABlock
    variant="outline"
    heading="Ready to be part of this?"
    body="Whether you want to join as a congregation, volunteer your time, or support the work with a gift — RCAN welcomes new partners."
    primaryLabel="Get involved"
    primaryHref="/get-involved"
    secondaryLabel="Donate"
    secondaryHref="/donate"
  />
</BaseLayout>
