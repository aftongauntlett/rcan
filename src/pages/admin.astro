---
import "../styles/global.css";
import "@fontsource/manrope/latin-400.css";
import "@fontsource/manrope/latin-700.css";
import AdminLogin from "../components/admin/AdminLogin.astro";
import AdminPortal from "../components/admin/AdminPortal.astro";
import PageChangeModal from "../components/admin/PageChangeModal.astro";
import { CHANGE_REQUESTS } from "../data/admin";

export const prerender = false;

const adminSession = Astro.cookies.get("admin_session")?.value;
const isAuthenticated = adminSession === "rcan-admin-authenticated";
---

<!doctype html>
<html lang="en" class="h-full bg-surface-default text-text-default">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — RCAN</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body class="flex min-h-full flex-col bg-surface-default font-sans text-text-default antialiased">
    {
      isAuthenticated ? (
        <>
          <AdminPortal requests={CHANGE_REQUESTS} />
          <PageChangeModal />
        </>
      ) : (
        <AdminLogin />
      )
    }

    <script>
      import { bootstrapAdminPortal } from "../utils/adminPortal";

      bootstrapAdminPortal();
      document.addEventListener("astro:page-load", () => bootstrapAdminPortal());
    </script>
  </body>
</html>
