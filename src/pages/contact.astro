---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import ContactMethods from "../components/ContactMethods.astro";

const pageTitle = "Contact RCAN | Returning Citizens Assistance Network";
const pageDescription =
  "Get in touch with RCAN for questions, referrals, partnerships, and community collaboration opportunities.";
const topicOptions = [
  { value: "", label: "Select a topic" },
  { value: "Become a Prison Friend", label: "Become a Prison Friend" },
  { value: "Engage your congregation", label: "Engage your congregation" },
  { value: "Provide direct assistance", label: "Provide direct assistance" },
  { value: "Become an RCAN volunteer", label: "Become an RCAN volunteer" },
  { value: "General question", label: "General question" },
];
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const isLocalDev = import.meta.env.DEV;
const turnstileEnabled = !isLocalDev && Boolean(turnstileSiteKey);
const localTurnstilePreviewSiteKey = "1x00000000000000000000AA";
const showTurnstileWidget = turnstileEnabled || isLocalDev;
const activeTurnstileSiteKey = turnstileEnabled ? turnstileSiteKey : localTurnstilePreviewSiteKey;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section
    aria-labelledby="contact-heading"
    class="border-b border-border-default pb-10 pt-2 md:pb-12"
  >
    <PageHeader id="contact-heading" heading="Connect with RCAN for partnership and support" />
  </section>

  <section class="pb-10" aria-labelledby="contact-methods-heading">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:gap-14">
      <ContactMethods />
      <ContactForm
        topicOptions={topicOptions}
        showTurnstileWidget={showTurnstileWidget}
        activeTurnstileSiteKey={activeTurnstileSiteKey}
        turnstileEnabled={turnstileEnabled}
      />
    </div>
  </section>

  <script>
    import { initContactPage } from "../utils/contactPage";

    initContactPage();
    document.addEventListener("astro:page-load", initContactPage);
  </script>
  {
    showTurnstileWidget && (
      <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
    )
  }
</BaseLayout>
