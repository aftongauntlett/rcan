---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import CTABlock from "../components/CTABlock.astro";
import CustomDropdown from "../components/CustomDropdown.astro";
import Icon from "../components/Icon.astro";
import postImage from "../assets/post.jpg";

const pageTitle = "Contact RCAN | Returning Citizens Assistance Network";
const pageDescription =
  "Get in touch with RCAN for questions, referrals, partnerships, and community collaboration opportunities.";
const topicOptions = [
  { value: "", label: "Select a topic" },
  { value: "Become a Prison Friend", label: "Become a Prison Friend" },
  { value: "Congregation partnership", label: "Congregation partnership" },
  { value: "Volunteer interest", label: "Volunteer interest" },
  { value: "Referral question", label: "Referral question" },
  { value: "General question", label: "General question" },
];
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const isLocalDev = import.meta.env.DEV;
const turnstileEnabled = !isLocalDev && Boolean(turnstileSiteKey);
const localTurnstilePreviewSiteKey = "1x00000000000000000000AA";
const showTurnstileWidget = turnstileEnabled || isLocalDev;
const activeTurnstileSiteKey = turnstileEnabled ? turnstileSiteKey : localTurnstilePreviewSiteKey;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="border-b border-border-default pb-10 pt-6 md:pt-8" aria-label="Contact overview">
    <SectionHeader
      level={1}
      heading="Connect with RCAN for partnership and support"
      subheading="Reach out to coordinate congregation participation, ask questions, or explore ways to support returning citizens."
    />
    <p class="mt-6 text-base leading-7 text-text-subtle">
      RCAN collaborates with referral partners and congregations and welcomes partnership from
      communities committed to practical, dignity-centered reentry support.
    </p>
  </section>

  <section class="pb-10" aria-labelledby="contact-methods-heading">
    <div class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10">
      <h2 id="contact-methods-heading" class="section-title text-text-subtle">Get in touch</h2>
      <p class="mt-4 text-base leading-7 text-text-subtle">
        We read every message that comes in and do our best to reply as quickly as possible, usually by email.
        Whether you have a question, a partnership idea, or are not sure where to start, please reach out and we
        will be in touch.
      </p>

      <div class="mt-8 grid gap-6 md:mt-10 md:grid-cols-[3fr_2fr] md:items-stretch">
        <article class="order-2 h-full md:order-1">
          <div class="flex h-full flex-col rounded-lg border border-border-default bg-surface-default px-6 py-6 md:justify-center md:px-7 md:py-6">
            <div data-fs-success role="status" aria-live="polite" class="text-sm font-semibold text-status-success"></div>
            <div data-fs-error role="alert" aria-live="assertive" class="text-sm font-semibold text-status-error"></div>

            <form id="contact-form" action="https://formspree.io/f/mdajaprb" method="POST" class="space-y-5 pt-1">
              <input type="hidden" name="_subject" value="RCAN website contact request" />
              <input type="hidden" name="source" value="contact-page" />
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

              <div class="grid gap-5 md:grid-cols-2">
                <div class="space-y-2">
                  <label for="first-name" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">First name</label>
                  <input
                    id="first-name"
                    name="firstName"
                    type="text"
                    autocomplete="given-name"
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="firstName" class="block text-sm text-status-error"></span>
                </div>

                <div class="space-y-2">
                  <label for="last-name" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Last name</label>
                  <input
                    id="last-name"
                    name="lastName"
                    type="text"
                    autocomplete="family-name"
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="lastName" class="block text-sm text-status-error"></span>
                </div>

                <div class="space-y-2">
                  <label for="phone" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Phone number</label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    autocomplete="tel"
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="phone" class="block text-sm text-status-error"></span>
                </div>

                <div class="space-y-2">
                  <label for="email" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Email address</label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    required
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="email" class="block text-sm text-status-error"></span>
                </div>
              </div>

              <div class="space-y-2">
                <label id="topic-label" for="topic-trigger" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">What are you reaching out about?</label>
                <CustomDropdown
                  id="topic"
                  name="topic"
                  labelledBy="topic-label"
                  options={topicOptions}
                  required
                  class="w-full"
                />
                <span data-fs-error="topic" class="block text-sm text-status-error"></span>
              </div>

              <div id="congregation-field-wrap" class="hidden space-y-2" data-congregation-field>
                <label for="congregation" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Congregation name</label>
                <input
                  id="congregation"
                  name="congregation"
                  type="text"
                  autocomplete="organization"
                  data-fs-field
                  class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                />
                <span data-fs-error="congregation" class="block text-sm text-status-error"></span>
              </div>

              <div class="mt-2 space-y-2">
                <label for="message" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows={6}
                  required
                  data-fs-field
                  class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                ></textarea>
                <span data-fs-error="message" class="block text-sm text-status-error"></span>
              </div>

              <div class="flex flex-wrap items-center justify-between gap-3">
                {
                  showTurnstileWidget ? (
                    <div class="cf-turnstile" data-sitekey={activeTurnstileSiteKey}></div>
                  ) : (
                    <div class="rounded-md border border-border-default bg-surface-subtle px-4 py-3 text-sm text-status-warning">
                      CAPTCHA is not configured yet. Add PUBLIC_TURNSTILE_SITE_KEY to enable submissions.
                    </div>
                  )
                }

                <Button
                  type="submit"
                  variant="primary"
                  size="md"
                  data-fs-submit-btn
                  disabled={!turnstileEnabled}
                >
                  <span data-fs-submit-label>Send message</span>
                </Button>
              </div>
              <span data-fs-error="cf-turnstile-response" class="text-sm text-status-error"></span>
            </form>
          </div>
        </article>

        <aside class="order-1 h-full md:order-2">
          <figure class="overflow-hidden rounded-lg border border-border-default bg-surface-default">
            <Image
              src={postImage}
              class="h-auto w-full object-cover"
              alt="A post-mounted mailbox representing direct communication and follow-up with RCAN."
              width={900}
              widths={[360, 540, 720, 900]}
              sizes="(min-width: 1024px) 40vw, 100vw"
              format="webp"
              quality={60}
              loading="lazy"
            />
          </figure>
        </aside>
      </div>
    </div>
  </section>

  <section class="pb-10" aria-labelledby="direct-contact-heading">
    <h2 id="direct-contact-heading" class="sr-only">Direct contact details</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <article class="group flex h-full flex-col rounded-lg border border-border-default bg-surface-default px-5 py-6 shadow-sm motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md" aria-labelledby="find-us-heading">
        <h3 id="find-us-heading" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Find Us</h3>
        <div class="mt-4 flex flex-1 items-center justify-center rounded-md border border-border-default bg-surface-subtle px-4 py-6 text-sm leading-6 text-text-subtle">
          <div class="flex max-w-sm flex-col items-center gap-3 text-center">
            <Icon name="map-pin" class="h-6 w-6 text-brand-secondary" aria-hidden="true" />
            <p>Map preview can be added once the address is finalized and API setup is complete.</p>
          </div>
        </div>
      </article>

      <article class="group rounded-lg border border-border-default bg-surface-default px-5 py-6 shadow-sm motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md" aria-labelledby="email-phone-heading">
        <h3 id="email-phone-heading" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Reach Out</h3>
        <div class="mt-3 space-y-3">
          <div data-copy-row class="group/row flex items-center justify-between gap-3 rounded-md border border-border-default bg-surface-default px-3 py-3 motion-safe:transition-colors motion-safe:duration-200 hover:border-brand-secondary hover:bg-surface-subtle">
            <div class="flex min-w-0 items-center gap-3 text-text-subtle">
              <Icon name="mail" class="h-4 w-4 text-brand-secondary motion-safe:transition-colors motion-safe:duration-200 group-hover/row:text-brand-primary" aria-hidden="true" />
              <p data-copy-text class="truncate text-sm font-medium">email@example.org</p>
            </div>
            <button
              type="button"
              data-copy-button
              data-copy-value="email@example.org"
              data-copy-feedback-id="email-copy-feedback"
              aria-label="Copy email address"
              class="inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-md text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
            >
              <span data-copy-icon class="inline-flex">
                <Icon name="copy" class="h-4 w-4" aria-hidden="true" />
              </span>
              <span data-copied-icon class="inline-flex" style="display:none">
                <Icon name="check" class="h-4 w-4" aria-hidden="true" />
              </span>
            </button>
          </div>

          <div data-copy-row class="group/row flex items-center justify-between gap-3 rounded-md border border-border-default bg-surface-default px-3 py-3 motion-safe:transition-colors motion-safe:duration-200 hover:border-brand-secondary hover:bg-surface-subtle">
            <div class="flex min-w-0 items-center gap-3 text-text-subtle">
              <Icon name="phone" class="h-4 w-4 text-brand-secondary motion-safe:transition-colors motion-safe:duration-200 group-hover/row:text-brand-primary" aria-hidden="true" />
              <p data-copy-text class="truncate text-sm font-medium">555-555-5555</p>
            </div>
            <button
              type="button"
              data-copy-button
              data-copy-value="555-555-5555"
              data-copy-feedback-id="phone-copy-feedback"
              aria-label="Copy phone number"
              class="inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-md text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
            >
              <span data-copy-icon class="inline-flex">
                <Icon name="copy" class="h-4 w-4" aria-hidden="true" />
              </span>
              <span data-copied-icon class="inline-flex" style="display:none">
                <Icon name="check" class="h-4 w-4" aria-hidden="true" />
              </span>
            </button>
          </div>

          <div data-copy-row class="group/row flex items-center justify-between gap-3 rounded-md border border-border-default bg-surface-default px-3 py-3 motion-safe:transition-colors motion-safe:duration-200 hover:border-brand-secondary hover:bg-surface-subtle">
            <div class="flex min-w-0 items-center gap-3 text-text-subtle">
              <Icon name="map-pin" class="h-4 w-4 text-brand-secondary motion-safe:transition-colors motion-safe:duration-200 group-hover/row:text-brand-primary" aria-hidden="true" />
              <p data-copy-text class="text-sm font-medium leading-6">
                Placeholder Mailing Address<br />
                Washington, DC 00000
              </p>
            </div>
            <button
              type="button"
              data-copy-button
              data-copy-value="Placeholder Mailing Address, Washington, DC 00000"
              data-copy-feedback-id="address-copy-feedback"
              aria-label="Copy mailing address"
              class="inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-md text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
            >
              <span data-copy-icon class="inline-flex">
                <Icon name="copy" class="h-4 w-4" aria-hidden="true" />
              </span>
              <span data-copied-icon class="inline-flex" style="display:none">
                <Icon name="check" class="h-4 w-4" aria-hidden="true" />
              </span>
            </button>
          </div>
        </div>
        <p id="email-copy-feedback" class="sr-only" aria-live="polite"></p>
        <p id="phone-copy-feedback" class="sr-only" aria-live="polite"></p>
        <p id="address-copy-feedback" class="sr-only" aria-live="polite"></p>
      </article>
    </div>
  </section>

  <script>
    import { initForm } from "@formspree/ajax";
    import {
      getCongregationFieldState,
      resolveCopyValue,
      shouldResetSubmitState,
    } from "../utils/contactInteractions";

    const initContactForm = () => {
      const form = document.querySelector("#contact-form");
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      const submitButton = form.querySelector("[data-fs-submit-btn]");
      const submitLabel = form.querySelector("[data-fs-submit-label]");
      const successMessage = document.querySelector("[data-fs-success]");
      const errorMessage = document.querySelector("[data-fs-error]");

      if (submitButton instanceof HTMLButtonElement) {
        if (submitButton.dataset.submitStateBound !== "true") {
          const initialDisabledState = submitButton.disabled;
          const defaultLabel =
            submitLabel instanceof HTMLElement
              ? submitLabel.textContent?.trim() || "Send message"
              : submitButton.textContent?.trim() || "Send message";

          const setSubmitState = (isSubmitting: boolean) => {
            submitButton.disabled = isSubmitting || initialDisabledState;

            if (submitLabel instanceof HTMLElement) {
              submitLabel.textContent = isSubmitting ? "Sending" : defaultLabel;
            } else {
              submitButton.textContent = isSubmitting ? "Sending" : defaultLabel;
            }

            if (isSubmitting) {
              form.setAttribute("aria-busy", "true");
            } else {
              form.removeAttribute("aria-busy");
            }
          };

          const resetFromMessage = () => {
            const successText = successMessage instanceof HTMLElement ? successMessage.textContent : "";
            const errorText = errorMessage instanceof HTMLElement ? errorMessage.textContent : "";

            if (shouldResetSubmitState(successText, errorText)) {
              setSubmitState(false);
            }
          };

          form.addEventListener("submit", () => {
            setSubmitState(true);
          });

          if (successMessage instanceof HTMLElement) {
            const observer = new MutationObserver(resetFromMessage);
            observer.observe(successMessage, {
              childList: true,
              characterData: true,
              subtree: true,
            });
          }

          if (errorMessage instanceof HTMLElement) {
            const observer = new MutationObserver(resetFromMessage);
            observer.observe(errorMessage, {
              childList: true,
              characterData: true,
              subtree: true,
            });
          }

          submitButton.dataset.submitStateBound = "true";
        }
      }

      if (form.dataset.formspreeBound === "true") {
        return;
      }

      try {
        initForm({ formElement: "#contact-form", formId: "mdajaprb" });
        form.dataset.formspreeBound = "true";
      } catch (error) {
        console.error("Formspree init failed", error);
      }
    };

    const topicFromQuery = new URLSearchParams(window.location.search).get("topic");
    const topicInput = document.querySelector("[data-dropdown-input][name='topic']");
    const congregationFieldWrap = document.querySelector("[data-congregation-field]");
    const congregationInput = document.querySelector("#congregation");

    const syncCongregationField = () => {
      if (!(topicInput instanceof HTMLInputElement)) {
        return;
      }

      const fieldState = getCongregationFieldState(topicInput.value);

      if (congregationFieldWrap instanceof HTMLElement) {
        congregationFieldWrap.classList.toggle("hidden", !fieldState.showField);
      }

      if (congregationInput instanceof HTMLInputElement) {
        congregationInput.required = fieldState.required;

        if (fieldState.shouldClearInput) {
          congregationInput.value = "";
          congregationInput.dispatchEvent(new Event("input", { bubbles: true }));
          congregationInput.dispatchEvent(new Event("change", { bubbles: true }));
        }
      }
    };

    const bindTopicListeners = () => {
      if (!(topicInput instanceof HTMLInputElement)) {
        return;
      }

      if (topicInput.dataset.contactTopicBound === "true") {
        return;
      }

      topicInput.addEventListener("change", syncCongregationField);
      topicInput.addEventListener("input", syncCongregationField);
      topicInput.dataset.contactTopicBound = "true";
    };

    const copyButtons = Array.from(document.querySelectorAll("[data-copy-button]"));

    const setCopyFeedback = (feedbackId: string, message: string) => {
      const feedback = document.getElementById(feedbackId);
      if (!(feedback instanceof HTMLElement)) {
        return;
      }

      feedback.textContent = message;

      window.setTimeout(() => {
        if (feedback.textContent === message) {
          feedback.textContent = "";
        }
      }, 2000);
    };

    const fallbackCopyText = (value: string): boolean => {
      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.style.position = "absolute";
      textarea.style.left = "-9999px";
      textarea.style.opacity = "0";
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();
      textarea.setSelectionRange(0, textarea.value.length);

      let copied = false;
      try {
        copied = document.execCommand("copy");
      } catch {
        copied = false;
      }

      document.body.removeChild(textarea);
      return copied;
    };

    const copyResetTimers = new WeakMap();

    const setCopyIconState = (button: HTMLButtonElement, copied: boolean) => {
      const copyIcon = button.querySelector("[data-copy-icon]");
      const copiedIcon = button.querySelector("[data-copied-icon]");

      if (!(copyIcon instanceof HTMLElement) || !(copiedIcon instanceof HTMLElement)) {
        return;
      }

      copyIcon.style.display = copied ? "none" : "inline-block";
      copiedIcon.style.display = copied ? "inline-block" : "none";
    };

    const bindCopyButtons = () => {
      copyButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      if (button.dataset.copyBound === "true") {
        return;
      }

      button.dataset.copyBound = "true";

      setCopyIconState(button, false);

      button.addEventListener("click", async () => {
        const row = button.closest("[data-copy-row]");
        const copyTextElement = row?.querySelector("[data-copy-text]");
        const valueFromRow = copyTextElement instanceof HTMLElement ? copyTextElement.innerText.trim() : "";
        const value = resolveCopyValue(valueFromRow, button.dataset.copyValue ?? "");
        const feedbackId = button.dataset.copyFeedbackId ?? "";
        if (!value || !feedbackId) {
          return;
        }

        let copied = false;

        if (navigator.clipboard?.writeText) {
          try {
            await navigator.clipboard.writeText(value);
            copied = true;
          } catch {
            copied = fallbackCopyText(value);
          }
        } else {
          copied = fallbackCopyText(value);
        }

        const existingReset = copyResetTimers.get(button);
        if (existingReset) {
          window.clearTimeout(existingReset);
        }

        setCopyIconState(button, copied);
        if (copied) {
          const resetHandle = window.setTimeout(() => {
            setCopyIconState(button, false);
            copyResetTimers.delete(button);
          }, 1500);
          copyResetTimers.set(button, resetHandle);
        }

        setCopyFeedback(feedbackId, copied ? "Copied" : "Unable to copy");
      });
    });
    };

    const initContactInteractions = () => {
      initContactForm();
      bindTopicListeners();
      bindCopyButtons();
      syncCongregationField();
    };

    initContactInteractions();
    document.addEventListener("astro:page-load", initContactInteractions);

    if (topicFromQuery) {
      const dropdownRoot = document.querySelector("[data-custom-dropdown]");
      if (dropdownRoot instanceof HTMLElement) {
        const input = dropdownRoot.querySelector("[data-dropdown-input]");
        const label = dropdownRoot.querySelector("[data-dropdown-label]");
        const options = Array.from(dropdownRoot.querySelectorAll("[data-dropdown-option]"));

        if (
          input instanceof HTMLInputElement
          && label instanceof HTMLElement
          && options.length > 0
        ) {
          const matchedOption = options.find((option) => {
            if (!(option instanceof HTMLButtonElement)) {
              return false;
            }

            return option.dataset.value === topicFromQuery;
          });

          if (matchedOption instanceof HTMLButtonElement) {
            options.forEach((option) => {
              if (!(option instanceof HTMLButtonElement)) {
                return;
              }

              const isSelected = option === matchedOption;
              option.setAttribute("aria-checked", isSelected ? "true" : "false");
              option.classList.toggle("bg-surface-subtle", isSelected);
              option.classList.toggle("text-brand-primary", isSelected);
              option.classList.toggle("text-text-default", !isSelected);

              const checkIcon = option.querySelector("[data-dropdown-check]");
              if (checkIcon instanceof HTMLElement) {
                checkIcon.classList.toggle("opacity-100", isSelected);
                checkIcon.classList.toggle("opacity-0", !isSelected);
              }
            });

            input.value = matchedOption.dataset.value ?? "";
            label.textContent = matchedOption.dataset.label ?? "";
            input.dispatchEvent(new Event("input", { bubbles: true }));
            input.dispatchEvent(new Event("change", { bubbles: true }));
          }
        }
      }
    }

  </script>
  {showTurnstileWidget && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}

  <section class="mt-6" aria-label="Next steps">
    <CTABlock
      heading="Take the next step"
      body="If you are ready to support this work right away, financial giving remains one of the fastest ways to strengthen RCAN's response capacity."
      primaryLabel="Donate"
      primaryHref="/donate"
      secondaryLabel="Get involved"
      secondaryHref="/get-involved"
    />
  </section>
</BaseLayout>
