---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";

const pageTitle = "Contact RCAN | Returning Citizens Assistance Network";
const pageDescription =
  "Get in touch with RCAN for questions, referrals, partnerships, and community collaboration opportunities.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <SectionHeader
    level={1}
    eyebrow="Connect"
    heading="Contact RCAN"
    subheading="This page will provide contact channels for inquiries and referrals."
  />
</BaseLayout>