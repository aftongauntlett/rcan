---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
import CustomDropdown from "../components/CustomDropdown.astro";
import Icon from "../components/Icon.astro";

const pageTitle = "Contact RCAN | Returning Citizens Assistance Network";
const pageDescription =
  "Get in touch with RCAN for questions, referrals, partnerships, and community collaboration opportunities.";
const topicOptions = [
  { value: "", label: "Select a topic" },
  { value: "Become a Prison Friend", label: "Become a Prison Friend" },
  { value: "Engage your congregation", label: "Engage your congregation" },
  { value: "Provide direct assistance", label: "Provide direct assistance" },
  { value: "Become an RCAN volunteer", label: "Become an RCAN volunteer" },
  { value: "General question", label: "General question" },
];
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const isLocalDev = import.meta.env.DEV;
const turnstileEnabled = !isLocalDev && Boolean(turnstileSiteKey);
const localTurnstilePreviewSiteKey = "1x00000000000000000000AA";
const showTurnstileWidget = turnstileEnabled || isLocalDev;
const activeTurnstileSiteKey = turnstileEnabled ? turnstileSiteKey : localTurnstilePreviewSiteKey;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section aria-labelledby="contact-heading" class="border-b border-border-default pb-10 pt-2 md:pb-12">
    <PageHeader
      id="contact-heading"
      eyebrow="Contact"
      heading="Connect with RCAN for partnership and support"
    />
  </section>

  <section class="pb-10" aria-labelledby="contact-methods-heading">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:gap-14">

      <!-- Left column: description + contact details -->
      <div class="lg:col-span-2">
        <div class="space-y-4">
          <p class="text-base leading-7 text-text-subtle">
            Whether you're a congregation looking to get involved, an individual with a question, or an
            organization exploring partnership, we'd love to hear from you.
          </p>
          <p class="text-base leading-7 text-text-subtle">
            RCAN welcomes partnership from communities committed to practical, dignity-centered reentry support.
            We read every message and do our best to reply quickly, usually by email.
          </p>
          <p class="text-base leading-7 text-text-subtle">
            Not sure where to start? Just say hello — we'll help point you in the right direction.
          </p>
        </div>

        <div class="mt-8 space-y-5" aria-labelledby="contact-methods-heading">
          <h2 id="contact-methods-heading" class="sr-only">Contact information</h2>

          <div data-copy-row class="group/row flex items-center gap-3 rounded-lg border border-border-default bg-surface-default px-4 py-3">
            <Icon name="mail" class="h-4 w-4 shrink-0 text-brand-secondary" aria-hidden="true" />
            <p data-copy-text class="flex-1 text-sm font-medium text-text-default">dcrcan2018@gmail.com</p>
            <button type="button" data-copy-button data-copy-value="dcrcan2018@gmail.com" data-copy-feedback-id="email-copy-feedback" aria-label="Copy email address" class="inline-flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-md text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
              <span data-copy-icon class="inline-flex"><Icon name="copy" class="h-3.5 w-3.5" aria-hidden="true" /></span>
              <span data-copied-icon class="inline-flex" style="display:none"><Icon name="check" class="h-3.5 w-3.5" aria-hidden="true" /></span>
            </button>
          </div>

          <div data-copy-row class="group/row flex items-center gap-3 rounded-lg border border-border-default bg-surface-default px-4 py-3">
            <Icon name="phone" class="h-4 w-4 shrink-0 text-brand-secondary" aria-hidden="true" />
            <p data-copy-text class="flex-1 text-sm font-medium text-text-default">555-555-5555</p>
            <button type="button" data-copy-button data-copy-value="555-555-5555" data-copy-feedback-id="phone-copy-feedback" aria-label="Copy phone number" class="inline-flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-md text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
              <span data-copy-icon class="inline-flex"><Icon name="copy" class="h-3.5 w-3.5" aria-hidden="true" /></span>
              <span data-copied-icon class="inline-flex" style="display:none"><Icon name="check" class="h-3.5 w-3.5" aria-hidden="true" /></span>
            </button>
          </div>

          <div data-copy-row class="group/row flex items-start gap-3 rounded-lg border border-border-default bg-surface-default px-4 py-3">
            <Icon name="map-pin" class="mt-0.5 h-4 w-4 shrink-0 text-brand-secondary" aria-hidden="true" />
            <p data-copy-text class="flex-1 text-sm font-medium leading-6 text-text-default">5109 Nannie Helen Burroughs Ave. NE<br />Washington, DC 20019</p>
            <button type="button" data-copy-button data-copy-value="5109 Nannie Helen Burroughs Ave. NE, Washington, DC 20019" data-copy-feedback-id="address-copy-feedback" aria-label="Copy mailing address" class="inline-flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-md text-text-subtle motion-safe:transition-colors motion-safe:duration-200 hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
              <span data-copy-icon class="inline-flex"><Icon name="copy" class="h-3.5 w-3.5" aria-hidden="true" /></span>
              <span data-copied-icon class="inline-flex" style="display:none"><Icon name="check" class="h-3.5 w-3.5" aria-hidden="true" /></span>
            </button>
          </div>
        </div>
        <p class="mt-3 text-sm leading-6 text-text-subtle">Mailing address only — for letters and correspondence. Please do not visit in person.</p>

        <p id="email-copy-feedback" class="sr-only" aria-live="polite"></p>
        <p id="phone-copy-feedback" class="sr-only" aria-live="polite"></p>
        <p id="address-copy-feedback" class="sr-only" aria-live="polite"></p>
      </div>

      <!-- Right column: contact form -->
      <div class="lg:col-span-3">
        <div class="rounded-xl bg-surface-subtle px-6 py-8 md:px-8">
          <div data-fs-success role="status" aria-live="polite" class="text-sm font-semibold text-status-success"></div>
          <div data-fs-error role="alert" aria-live="assertive" class="text-sm font-semibold text-status-error"></div>

          <form id="contact-form" action="https://formspree.io/f/mdajaprb" method="POST" class="space-y-5">
              <input type="hidden" name="_subject" value="RCAN website contact request" />
              <input type="hidden" name="source" value="contact-page" />
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

              <div class="grid gap-5 md:grid-cols-2">
                <div class="space-y-2">
                  <label for="first-name" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">First name</label>
                  <input
                    id="first-name"
                    name="firstName"
                    type="text"
                    autocomplete="given-name"
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="firstName" class="block text-sm text-status-error"></span>
                </div>

                <div class="space-y-2">
                  <label for="last-name" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Last name</label>
                  <input
                    id="last-name"
                    name="lastName"
                    type="text"
                    autocomplete="family-name"
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="lastName" class="block text-sm text-status-error"></span>
                </div>

                <div class="space-y-2">
                  <label for="phone" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Phone number</label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    autocomplete="tel"
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="phone" class="block text-sm text-status-error"></span>
                </div>

                <div class="space-y-2">
                  <label for="email" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Email address</label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    required
                    data-fs-field
                    class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                  />
                  <span data-fs-error="email" class="block text-sm text-status-error"></span>
                </div>
              </div>

              <div class="space-y-2">
                <label id="topic-label" for="topic-trigger" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">What are you reaching out about?</label>
                <CustomDropdown
                  id="topic"
                  name="topic"
                  labelledBy="topic-label"
                  options={topicOptions}
                  required
                  class="w-full"
                />
                <span data-fs-error="topic" class="block text-sm text-status-error"></span>
              </div>

              <div class="space-y-2">
                <label for="congregation" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Congregation or organization (if any)</label>
                <input
                  id="congregation"
                  name="congregation"
                  type="text"
                  autocomplete="organization"
                  data-fs-field
                  class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                />
                <span data-fs-error="congregation" class="block text-sm text-status-error"></span>
              </div>

              <div class="mt-2 space-y-2">
                <label for="message" class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows={6}
                  required
                  data-fs-field
                  class="w-full rounded-md border border-border-default bg-surface-default px-3 py-2 text-base text-text-default placeholder:text-text-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
                ></textarea>
                <span data-fs-error="message" class="block text-sm text-status-error"></span>
              </div>

              <div class="flex flex-wrap items-center justify-between gap-3">
                {
                  showTurnstileWidget ? (
                    <div class="cf-turnstile" data-sitekey={activeTurnstileSiteKey}></div>
                  ) : (
                    <div class="rounded-md border border-border-default bg-surface-subtle px-4 py-3 text-sm text-status-warning">
                      CAPTCHA is not configured yet. Add PUBLIC_TURNSTILE_SITE_KEY to enable submissions.
                    </div>
                  )
                }

                <Button
                  type="submit"
                  variant="primary"
                  size="md"
                  data-fs-submit-btn
                  disabled={!turnstileEnabled}
                >
                  <span data-fs-submit-label>Send message</span>
                </Button>
              </div>
              <span data-fs-error="cf-turnstile-response" class="text-sm text-status-error"></span>
            </form>
          </div>
        </div>
      </div>

    </div>
  </section>

  <script>
    import { initForm } from "@formspree/ajax";
    import {
      resolveCopyValue,
      shouldResetSubmitState,
    } from "../utils/contactInteractions";

    const initContactForm = () => {
      const form = document.querySelector("#contact-form");
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      const submitButton = form.querySelector("[data-fs-submit-btn]");
      const submitLabel = form.querySelector("[data-fs-submit-label]");
      const successMessage = document.querySelector("[data-fs-success]");
      const errorMessage = document.querySelector("[data-fs-error]");

      if (submitButton instanceof HTMLButtonElement) {
        if (submitButton.dataset.submitStateBound !== "true") {
          const initialDisabledState = submitButton.disabled;
          const defaultLabel =
            submitLabel instanceof HTMLElement
              ? submitLabel.textContent?.trim() || "Send message"
              : submitButton.textContent?.trim() || "Send message";

          const setSubmitState = (isSubmitting: boolean) => {
            submitButton.disabled = isSubmitting || initialDisabledState;

            if (submitLabel instanceof HTMLElement) {
              submitLabel.textContent = isSubmitting ? "Sending" : defaultLabel;
            } else {
              submitButton.textContent = isSubmitting ? "Sending" : defaultLabel;
            }

            if (isSubmitting) {
              form.setAttribute("aria-busy", "true");
            } else {
              form.removeAttribute("aria-busy");
            }
          };

          const resetFromMessage = () => {
            const successText = successMessage instanceof HTMLElement ? successMessage.textContent : "";
            const errorText = errorMessage instanceof HTMLElement ? errorMessage.textContent : "";

            if (shouldResetSubmitState(successText, errorText)) {
              setSubmitState(false);
            }
          };

          form.addEventListener("submit", () => {
            setSubmitState(true);
          });

          if (successMessage instanceof HTMLElement) {
            const observer = new MutationObserver(resetFromMessage);
            observer.observe(successMessage, {
              childList: true,
              characterData: true,
              subtree: true,
            });
          }

          if (errorMessage instanceof HTMLElement) {
            const observer = new MutationObserver(resetFromMessage);
            observer.observe(errorMessage, {
              childList: true,
              characterData: true,
              subtree: true,
            });
          }

          submitButton.dataset.submitStateBound = "true";
        }
      }

      if (form.dataset.formspreeBound === "true") {
        return;
      }

      try {
        initForm({ formElement: "#contact-form", formId: "mdajaprb" });
        form.dataset.formspreeBound = "true";
      } catch (error) {
        console.error("Formspree init failed", error);
      }
    };

    const topicFromQuery = new URLSearchParams(window.location.search).get("topic");

    const copyButtons = Array.from(document.querySelectorAll("[data-copy-button]"));

    const setCopyFeedback = (feedbackId: string, message: string) => {
      const feedback = document.getElementById(feedbackId);
      if (!(feedback instanceof HTMLElement)) {
        return;
      }

      feedback.textContent = message;

      window.setTimeout(() => {
        if (feedback.textContent === message) {
          feedback.textContent = "";
        }
      }, 2000);
    };

    const fallbackCopyText = (value: string): boolean => {
      const textarea = document.createElement("textarea");
      textarea.value = value;
      textarea.style.position = "absolute";
      textarea.style.left = "-9999px";
      textarea.style.opacity = "0";
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();
      textarea.setSelectionRange(0, textarea.value.length);

      // execCommand is deprecated but still the only copy path for browsers/contexts
      // without navigator.clipboard; cast to a plain signature to avoid the deprecation
      // diagnostic on an intentional fallback.
      const execCommandCopy = document.execCommand.bind(document) as (commandId: string) => boolean;

      let copied = false;
      try {
        copied = execCommandCopy("copy");
      } catch {
        copied = false;
      }

      document.body.removeChild(textarea);
      return copied;
    };

    const copyResetTimers = new WeakMap();

    const setCopyIconState = (button: HTMLButtonElement, copied: boolean) => {
      const copyIcon = button.querySelector("[data-copy-icon]");
      const copiedIcon = button.querySelector("[data-copied-icon]");

      if (!(copyIcon instanceof HTMLElement) || !(copiedIcon instanceof HTMLElement)) {
        return;
      }

      copyIcon.style.display = copied ? "none" : "inline-block";
      copiedIcon.style.display = copied ? "inline-block" : "none";
    };

    const bindCopyButtons = () => {
      copyButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      if (button.dataset.copyBound === "true") {
        return;
      }

      button.dataset.copyBound = "true";

      setCopyIconState(button, false);

      button.addEventListener("click", async () => {
        const row = button.closest("[data-copy-row]");
        const copyTextElement = row?.querySelector("[data-copy-text]");
        const valueFromRow = copyTextElement instanceof HTMLElement ? copyTextElement.innerText.trim() : "";
        const value = resolveCopyValue(valueFromRow, button.dataset.copyValue ?? "");
        const feedbackId = button.dataset.copyFeedbackId ?? "";
        if (!value || !feedbackId) {
          return;
        }

        let copied = false;

        if (navigator.clipboard?.writeText) {
          try {
            await navigator.clipboard.writeText(value);
            copied = true;
          } catch {
            copied = fallbackCopyText(value);
          }
        } else {
          copied = fallbackCopyText(value);
        }

        const existingReset = copyResetTimers.get(button);
        if (existingReset) {
          window.clearTimeout(existingReset);
        }

        setCopyIconState(button, copied);
        if (copied) {
          const resetHandle = window.setTimeout(() => {
            setCopyIconState(button, false);
            copyResetTimers.delete(button);
          }, 1500);
          copyResetTimers.set(button, resetHandle);
        }

        setCopyFeedback(feedbackId, copied ? "Copied" : "Unable to copy");
      });
    });
    };

    const initContactInteractions = () => {
      initContactForm();
      bindCopyButtons();
    };

    initContactInteractions();
    document.addEventListener("astro:page-load", initContactInteractions);

    if (topicFromQuery) {
      const dropdownRoot = document.querySelector("[data-custom-dropdown]");
      if (dropdownRoot instanceof HTMLElement) {
        const input = dropdownRoot.querySelector("[data-dropdown-input]");
        const label = dropdownRoot.querySelector("[data-dropdown-label]");
        const options = Array.from(dropdownRoot.querySelectorAll("[data-dropdown-option]"));

        if (
          input instanceof HTMLInputElement
          && label instanceof HTMLElement
          && options.length > 0
        ) {
          const matchedOption = options.find((option) => {
            if (!(option instanceof HTMLButtonElement)) {
              return false;
            }

            return option.dataset.value === topicFromQuery;
          });

          if (matchedOption instanceof HTMLButtonElement) {
            options.forEach((option) => {
              if (!(option instanceof HTMLButtonElement)) {
                return;
              }

              const isSelected = option === matchedOption;
              option.setAttribute("aria-checked", isSelected ? "true" : "false");
              option.classList.toggle("bg-surface-subtle", isSelected);
              option.classList.toggle("text-brand-primary", isSelected);
              option.classList.toggle("text-text-default", !isSelected);

              const checkIcon = option.querySelector("[data-dropdown-check]");
              if (checkIcon instanceof HTMLElement) {
                checkIcon.classList.toggle("opacity-100", isSelected);
                checkIcon.classList.toggle("opacity-0", !isSelected);
              }
            });

            input.value = matchedOption.dataset.value ?? "";
            label.textContent = matchedOption.dataset.label ?? "";
            input.dispatchEvent(new Event("input", { bubbles: true }));
            input.dispatchEvent(new Event("change", { bubbles: true }));
          }
        }
      }
    }

  </script>
  {showTurnstileWidget && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
</BaseLayout>
