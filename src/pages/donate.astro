---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import PageHeader from "../components/PageHeader.astro";
import SectionTitle from "../components/SectionTitle.astro";
import Button from "../components/Button.astro";
import BulletList from "../components/BulletList.astro";
import donateImage from "../assets/make-change.jpg";

const pageTitle = "Donate | RCAN";
const pageDescription =
  "Support RCAN's mission with financial contributions that expand resources for returning citizens.";

const donorboxEmbedUrl = import.meta.env.PUBLIC_DONORBOX_EMBED_URL?.trim();
const hasDonorboxEmbed = Boolean(donorboxEmbedUrl);
const isDev = import.meta.env.DEV;
const donorboxFrameHeight = 720;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section aria-labelledby="donate-heading" class="border-b border-border-default pb-10 pt-2 md:pb-12">
    <PageHeader
      id="donate-heading"
      eyebrow="Donate"
      heading="Fuel practical support for returning citizens"
      subheading="RCAN's ministry is sustained through the generosity of dedicated members and friends."
    />
  </section>

  <section id="donate-form" class="py-10" aria-labelledby="give-heading">
    <SectionTitle id="give-heading" text="Give to RCAN" />
    <div class="mx-auto mt-6 max-w-2xl space-y-4 text-center text-base leading-7 text-text-subtle">
      <p>
        Your gift helps RCAN respond quickly to urgent requests for housing, food, transportation,
        and other practical barriers that can delay reentry stability. The RCAN Fund was established
        through New York Avenue Presbyterian Church in January 2021 to facilitate online donations
        supporting client requests from the DC Public Defender Service. Each December since 2020, RCAN
        has prepared holiday gift baskets for PDS-selected families and individuals — in 2025, ten
        families (51 adults and children) received gifts by Christmas, and 36 incarcerated clients
        without outside support each received $50 in commissary funds. In all, 2025 contributions
        helped 361 clients.
      </p>
      <p>
        Every contribution supports practical, short-term needs identified through RCAN's
        referral channels. Support is processed securely through Donorbox.
      </p>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[3fr_2fr] lg:items-stretch">
      <div class="h-full">
        {
          hasDonorboxEmbed ? (
            <iframe
              src={donorboxEmbedUrl}
              title="Secure donation form powered by Donorbox"
              name="donorbox-donation-form"
              class="w-full rounded-lg border border-border-default bg-surface-default"
              loading="lazy"
              height={donorboxFrameHeight}
              allow="payment"
            ></iframe>
          ) : isDev ? (
            <aside
              class="flex h-full items-center rounded-lg border border-border-default bg-surface-default px-6 py-8"
              aria-label="Donation embed preview helper"
            >
              <div>
                <p class="text-sm font-semibold uppercase tracking-wide text-text-default">Donorbox preview</p>
                <p class="mt-2 text-base leading-7 text-text-subtle">
                  Add a value for <strong>PUBLIC_DONORBOX_EMBED_URL</strong> to render the live donation
                  iframe in this section.
                </p>
              </div>
            </aside>
          ) : (
            <aside
              class="flex h-full items-center rounded-lg border border-border-default bg-surface-default px-6 py-8"
              aria-label="Donation form unavailable"
            >
              <div>
                <p class="text-sm font-semibold uppercase tracking-wide text-text-default">Donation form temporarily unavailable</p>
                <p class="mt-2 text-base leading-7 text-text-subtle">
                  The online donation form is not configured right now. Contact RCAN and we will help
                  you complete your gift.
                </p>
                <div class="mt-4">
                  <Button href="/contact" variant="secondary" size="sm">Contact RCAN</Button>
                </div>
              </div>
            </aside>
          )
        }
      </div>

      <aside id="mail-giving" class="h-full rounded-lg border border-border-default bg-surface-default px-6 py-8" aria-labelledby="mail-giving-heading">
        <h3 id="mail-giving-heading" class="text-sm font-semibold uppercase tracking-wide text-text-default">Prefer to give by mail?</h3>
        <p class="mt-3 text-base leading-7 text-text-subtle">
          Make checks payable to New York Avenue Presbyterian Church and mail to:
        </p>
        <address class="mt-3 not-italic text-base leading-7 text-text-subtle">
          Placeholder Mailing Address<br />
          Washington, DC 00000
        </address>
        <div class="mt-6 border-t border-border-default pt-5" aria-label="Direct contact options">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-secondary">Direct contact</p>
          <ul class="mt-3 space-y-2 text-base leading-7 text-text-subtle">
            <li>
              <a
                href="mailto:email@example.org"
                class="underline decoration-brand-primary underline-offset-2 transition-colors duration-base hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default"
              >
                email@example.org
              </a>
            </li>
            <li>
              <a
                href="tel:555-555-5555"
                class="underline decoration-brand-primary underline-offset-2 transition-colors duration-base hover:text-brand-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default"
              >
                555-555-5555
              </a>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="py-10" aria-labelledby="impact-heading">
    <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
      <figure class="overflow-hidden rounded-lg shadow-md">
        <Image
          src={donateImage}
          class="h-full w-full object-cover"
          alt="Hands holding coins and a note reading Make a change, representing direct financial support for community impact."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          format="webp"
          quality={60}
          loading="lazy"
        />
      </figure>

      <article>
        <SectionTitle id="impact-heading" text="What your gift supports" align="left" />
        <BulletList
          items={[
            "Emergency support that prevents avoidable setbacks during reentry.",
            "Housing-related costs (application fees, deposits, utilities).",
            "Transportation support (Metro cards, rides, bicycles).",
            "Essential needs (food, clothing, hygiene).",
            "Coordinated congregation response to urgent requests.",
            "Program support that sustains ongoing client stabilization.",
          ]}
        />
        <p class="mt-6 text-base leading-7 text-text-subtle">
          RCAN prioritizes urgent practical barriers so returning citizens can focus on long-term
          stability.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
