---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import donateImage from "../assets/make-change.jpg";

const pageTitle = "Donate | RCAN";
const pageDescription =
  "Support RCAN's mission with financial contributions that expand resources for returning citizens.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="relative isolate overflow-hidden rounded-lg border border-border-default bg-surface-subtle px-6 py-8 md:px-8 md:py-10">
    <div aria-hidden="true" class="pointer-events-none absolute -right-10 -top-10 h-40 w-40 rounded-full bg-brand-primary/10 blur-2xl"></div>
    <div class="relative grid gap-8 lg:grid-cols-2 lg:items-center">
      <article class="space-y-6">
        <SectionHeader
          level={1}
          eyebrow="Donate"
          heading="Fuel practical support for returning citizens"
          subheading="RCAN's ministry is sustained entirely through the generosity of dedicated members and friends."
        />
        <p class="max-w-4xl text-base leading-7 text-text-subtle">
          Through your support, congregations can respond quickly to urgent needs and help make
          pathways to stability more attainable.
        </p>
        <div class="flex flex-wrap items-center gap-3 md:justify-start">
          <Button href="https://nyapc.org/give/" variant="primary" size="lg">Give online now</Button>
        </div>
      </article>

      <figure class="overflow-hidden rounded-lg border border-border-default bg-surface-default shadow-lg">
        <Image
          src={donateImage}
          class="h-full w-full object-cover"
          alt="Hands holding coins and a note reading Make a change, representing direct financial support for community impact."
          width={800}
          widths={[320, 480, 568, 640, 720, 800]}
          sizes="(min-width: 1280px) 568px, (min-width: 1024px) calc((100vw - 9rem) / 2), 100vw"
          format="webp"
          quality={55}
          loading="eager"
          priority
        />
      </figure>
    </div>
  </section>

  <section class="py-10" aria-labelledby="ways-to-give-heading">
    <h2 id="ways-to-give-heading" class="section-title text-2xl font-semibold text-text-default">Ways to give</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <Card class="h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Online</p>
        <p class="mt-2 text-base leading-7 text-text-subtle">
          Visit the give page and select RCAN Returning Citizens from the dropdown menu.
        </p>
        <div class="mt-4">
          <Button href="https://nyapc.org/give/" variant="primary" size="md">Donate through NYAPC Give</Button>
        </div>
      </Card>

      <Card class="h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">By mail</p>
        <p class="mt-2 text-base leading-7 text-text-subtle">Send your contribution to:</p>
        <address class="mt-2 not-italic text-base leading-7 text-text-subtle">
          New York Avenue Presbyterian Church<br />
          1313 New York Avenue NW<br />
          Washington, DC 20005
        </address>
      </Card>
    </div>
  </section>

  <section class="py-10" aria-labelledby="impact-heading">
    <h2 id="impact-heading" class="section-title text-2xl font-semibold text-text-default">What your gift supports</h2>
    <ul class="mt-6 grid gap-4 md:grid-cols-3">
      <li>
        <Card class="group h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
          <p class="flex items-start gap-3 text-base text-text-subtle">
            <Icon
              name="heart"
              size="sm"
              class="mt-1 text-status-success transition-transform duration-base group-hover:scale-110"
              aria-hidden="true"
            />
            <span>Emergency support to prevent avoidable setbacks during reentry.</span>
          </p>
        </Card>
      </li>
      <li>
        <Card class="group h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
          <p class="flex items-start gap-3 text-base text-text-subtle">
            <Icon
              name="home"
              size="sm"
              class="mt-1 text-status-success transition-transform duration-base group-hover:scale-110"
              aria-hidden="true"
            />
            <span>Housing-related costs that improve stability and continuity.</span>
          </p>
        </Card>
      </li>
      <li>
        <Card class="group h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
          <p class="flex items-start gap-3 text-base text-text-subtle">
            <Icon
              name="users"
              size="sm"
              class="mt-1 text-status-success transition-transform duration-base group-hover:scale-110"
              aria-hidden="true"
            />
            <span>Coordinated congregation response across the RCAN network.</span>
          </p>
        </Card>
      </li>
    </ul>
  </section>
</BaseLayout>