---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import BulletList from "../components/BulletList.astro";
import donateImage from "../assets/make-change.jpg";

const pageTitle = "Donate | RCAN";
const pageDescription =
  "Support RCAN's mission with financial contributions that expand resources for returning citizens.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="py-10 md:py-14" aria-label="Donate">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-stretch">
      <article class="flex h-full flex-col gap-6">
        <SectionHeader
          level={1}
          heading="Fuel practical support for returning citizens"
          subheading="RCAN's ministry is sustained entirely through the generosity of dedicated members and friends."
        />
        <p class="text-base leading-7 text-text-subtle">
          Through your support, congregations can respond quickly to urgent needs and help make
          pathways to stability more attainable.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <Button href="#donate-form" variant="primary" size="lg">Give now</Button>
        </div>
      </article>

      <figure class="overflow-hidden rounded-lg shadow-lg">
        <Image
          src={donateImage}
          class="h-full min-h-80 w-full object-cover"
          alt="Hands holding coins and a note reading Make a change, representing direct financial support for community impact."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          format="webp"
          quality={60}
          loading="eager"
          priority
        />
      </figure>
    </div>
  </section>

  <section id="donate-form" class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="give-heading">
    <h2 id="give-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Give to RCAN</h2>
    <p class="mt-2 text-base leading-7 text-text-subtle">Support is processed securely through Donorbox.</p>

    <div class="mt-6">
      <!-- PLACEHOLDER: Replace with your live Donorbox campaign embed code once configured. -->
      <!-- Example: <iframe src="https://donorbox.org/embed/rcan-returning-citizens" ... /> -->
      <div class="flex min-h-96 items-center justify-center rounded-lg border-2 border-dashed border-border-default bg-surface-default">
        <div class="space-y-3 px-6 py-10 text-center">
          <p class="text-sm font-semibold uppercase tracking-wide text-text-subtle">Donorbox Embed</p>
          <p class="mx-auto max-w-sm text-base text-text-subtle">
            The donation form will appear here once the Donorbox campaign is configured. Replace this
            block with the Donorbox iframe embed code.
          </p>
          <p class="text-xs text-text-subtle italic">
            Placeholder — not visible in production once embed is added.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 border-t border-border-default pt-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">Prefer to give by mail?</p>
      <address class="mt-2 not-italic text-base leading-7 text-text-subtle">
        New York Avenue Presbyterian Church<br />
        1313 New York Avenue NW<br />
        Washington, DC 20005
      </address>
    </div>
  </section>

  <section class="py-10" aria-labelledby="impact-heading">
    <h2 id="impact-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">What your gift supports</h2>
    <BulletList
      items={[
        "Emergency support to prevent avoidable setbacks during reentry.",
        "Housing-related costs that improve stability and continuity.",
        "Coordinated congregation response across the RCAN network.",
      ]}
    />
  </section>
</BaseLayout>