---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import CTABlock from "../components/CTABlock.astro";
import CountUpScript from "../components/CountUpScript.astro";
import IconSupportList from "../components/IconSupportList.astro";
import faithImage from "../assets/faith.jpg";

const pageTitle = "Get Involved | RCAN";
const pageDescription =
  "Find ways to volunteer, partner, and participate in RCAN's work supporting returning citizens.";

const congregationCommitments = [
  {
    icon: "check",
    label: "Step 1",
    text: "Receive regular information from the network about specific individuals who need assistance",
  },
  {
    icon: "check",
    label: "Step 2",
    text: "Check with members of the congregation to see if anyone can assist with a specific request",
  },
  {
    icon: "check",
    label: "Step 3",
    text: "Help to coordinate the efforts of those who want to respond to requests",
  },
] as const;

const waysToHelp = [
  {
    icon: "heart",
    text: "Directly support urgent requests with goods, services, or short-term financial help for people in transition.",
  },
  {
    icon: "users",
    text: "Coordinate volunteers through your congregation to organize practical responses to specific needs.",
  },
  {
    icon: "user",
    text: "Build one-to-one encouragement and mentoring relationships that support stability during reentry.",
  },
  {
    icon: "dollar-sign",
    text: "Give financially for urgent needs and remove barriers to reentry, including transit, housing, and essentials.",
  },
  {
    icon: "mail",
    text: "Become a Prison Friend and build consistent encouragement through letters and shared reading materials.",
    cta: { label: "Learn more", href: "/how-we-help#prison-friendship-project" },
  },
  {
    icon: "book-open",
    text: "Share practical resources with RCAN and help connect your community to meaningful opportunities to respond.",
  },
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="border-b border-border-default pb-10 pt-6 md:pt-8" aria-labelledby="get-involved-heading">
    <SectionHeader
      id="get-involved-heading"
      level={1}
      heading="Bring your strengths to RCAN."
      subheading="RCAN brings together individuals, small groups, and congregations to respond to urgent needs that can otherwise derail successful reentry. Whether support comes through direct help, coordinated volunteers, sustained friendship, or financial giving, every pathway strengthens stability and dignity for people returning home."
    />
    <p class="mt-6 text-base leading-7 text-text-subtle">
      RCAN welcomes individuals, small groups, and congregations who are ready to respond to
      practical needs with care, consistency, and dignity.
    </p>
    <p class="mt-4 text-base leading-7 text-text-subtle">
      You can volunteer, join as a congregation partner, become a Prison Friend, or donate to help
      remove barriers that threaten successful reentry.
    </p>
  </section>

  <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="ways-heading">
    <h2 id="ways-heading" class="section-title text-text-subtle">Ways to help</h2>
    <p class="mt-2 text-sm leading-6 text-text-subtle">
      These pathways are open to anyone who wants to support returning citizens, whether you are
      participating individually or through a congregation.
    </p>
    <IconSupportList items={waysToHelp} ariaLabel="Ways to get involved with RCAN" sentenceEndCta />
  </section>

  <section class="py-10" aria-labelledby="commitments-heading">
    <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
      <figure class="overflow-hidden rounded-lg shadow-md">
        <Image
          src={faithImage}
          class="h-full w-full object-cover"
          alt="Members gathered in faith community, representing congregation partnership and coordinated support."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          format="webp"
          quality={60}
          loading="lazy"
        />
      </figure>

      <div>
        <h2 id="commitments-heading" class="section-title text-text-subtle">Congregation commitments</h2>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-text-subtle">Any congregation that joins RCAN agrees to three commitments:</p>
        <IconSupportList
          items={congregationCommitments}
          ordered
          columns={1}
          ariaLabel="Congregation commitments"
          class="max-w-2xl"
        />
      </div>
    </div>
  </section>

  <CTABlock
    heading="Ready to help in a way that fits you?"
    body="If you want to volunteer, partner through your congregation, become a Prison Friend, or support urgent needs financially, RCAN can help you take the next step. You can donate now or contact us to get involved."
    primaryLabel="Donate"
    primaryHref="/donate"
    secondaryLabel="Contact"
    secondaryHref="/contact"
    variant="outline"
  />

  <CountUpScript />
</BaseLayout>