---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import PageHeader from "../components/PageHeader.astro";
import SectionTitle from "../components/SectionTitle.astro";
import IconCardGrid from "../components/IconCardGrid.astro";
import CTABlock from "../components/CTABlock.astro";
import CountUpScript from "../components/CountUpScript.astro";
import IconSupportList from "../components/IconSupportList.astro";
import faithImage from "../assets/faith.jpg";

const pageTitle = "Get Involved | RCAN";
const pageDescription =
  "Find ways to volunteer, partner, and participate in RCAN's work supporting returning citizens.";

const congregationCommitments = [
  {
    icon: "check",
    label: "Step 1",
    text: "Receive regular information from the network about specific individuals who need assistance",
  },
  {
    icon: "check",
    label: "Step 2",
    text: "Check with members of the congregation to see if anyone can assist with a specific request",
  },
  {
    icon: "check",
    label: "Step 3",
    text: "Help to coordinate the efforts of those who want to respond to requests",
  },
] as const;

const waysToHelp = [
  {
    icon: "mail",
    label: "Become a Prison Friend",
    description: "Build consistent encouragement through letters and shared reading materials with someone currently incarcerated.",
  },
  {
    icon: "users",
    label: "Engage your congregation",
    description: "Coordinate volunteers through your congregation to organize practical responses to specific reentry needs.",
  },
  {
    icon: "hand-heart",
    label: "Provide direct assistance",
    description: "Support urgent requests with goods, services, or short-term financial help for returning citizens and their families.",
  },
  {
    icon: "user",
    label: "Become an RCAN volunteer",
    description: "Build one-to-one mentoring relationships and help connect your community to meaningful opportunities to respond.",
  },
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section aria-labelledby="get-involved-heading" class="border-b border-border-default pb-10 pt-2 md:pb-12">
    <PageHeader
      id="get-involved-heading"
      eyebrow="Get Involved"
      heading="Bring your strengths to RCAN."
      subheading="RCAN brings together individuals, small groups, and congregations to respond to urgent needs that can otherwise derail successful reentry."
    />
  </section>

  <section aria-labelledby="ways-heading">
    <SectionTitle id="ways-heading" text="Ways to help" />
    <div class="mx-auto mt-6 max-w-2xl space-y-4 text-center text-base leading-7 text-text-subtle">
      <p>
        Whether support comes through direct help, coordinated volunteers, sustained friendship, or
        financial giving, every pathway strengthens stability and dignity for people returning home.
      </p>
      <p>
        RCAN welcomes individuals, small groups, and congregations who are ready to respond to
        practical needs with care, consistency, and dignity. You can volunteer, join as a
        congregation partner, become a Prison Friend, or donate to help remove barriers that
        threaten successful reentry.
      </p>
      <p>
        These pathways are open to anyone who wants to support returning citizens, whether you are
        participating individually or through a congregation.
      </p>
    </div>
    <IconCardGrid items={waysToHelp} ariaLabel="Ways to get involved with RCAN" columns={4} />
  </section>

  <section class="py-10" aria-labelledby="commitments-heading">
    <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
      <figure class="overflow-hidden rounded-lg shadow-md">
        <Image
          src={faithImage}
          class="h-full w-full object-cover"
          alt="Members gathered in faith community, representing congregation partnership and coordinated support."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          format="webp"
          quality={60}
          loading="lazy"
        />
      </figure>

      <div>
        <SectionTitle id="commitments-heading" text="Congregation commitments" align="left" />
        <p class="mt-2 max-w-2xl text-sm leading-6 text-text-subtle">Any congregation that joins RCAN agrees to three commitments:</p>
        <IconSupportList
          items={congregationCommitments}
          ordered
          columns={1}
          ariaLabel="Congregation commitments"
          class="max-w-2xl"
        />
      </div>
    </div>
  </section>

  <CTABlock
    heading="Ready to help in a way that fits you?"
    body="If you want to volunteer, partner through your congregation, become a Prison Friend, or support urgent needs financially, RCAN can help you take the next step. You can donate now or contact us to get involved."
    primaryLabel="Donate"
    primaryHref="/donate"
    secondaryLabel="Contact"
    secondaryHref="/contact"
    variant="fill"
  />

  <CountUpScript />
</BaseLayout>