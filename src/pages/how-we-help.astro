---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import supportImage from "../assets/art-community.jpg";

const pageTitle = "How We Help | RCAN";
const pageDescription =
  "Explore the support pathways and services RCAN coordinates for returning citizens and their families.";

const assistanceExamples = [
  "Providing clothes and food for those just out of prison",
  "Giving informal life-skills counseling or short-term mentoring",
  "Helping to find an apartment or paying an application fee or security deposit",
  "Writing and sending books to those who are still incarcerated",
  "Collecting donated furniture to help furnish apartments for returning citizens",
  "Providing funds to avoid eviction or helping with other emergency needs",
  "Helping with official documents or, under power of attorney, doing other tasks",
  "Assisting efforts to find work by navigating applications or connecting with prospective employers",
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="relative isolate overflow-hidden rounded-lg border border-border-default bg-surface-subtle px-6 py-8 md:px-8 md:py-10">
    <div aria-hidden="true" class="pointer-events-none absolute -right-10 -top-10 h-40 w-40 rounded-full bg-brand-primary/10 blur-2xl"></div>
    <div class="relative grid gap-8 lg:grid-cols-2 lg:items-center">
      <article class="space-y-6">
        <SectionHeader
          level={1}
          eyebrow="How We Help"
          heading="Practical support when timing matters most"
          subheading="RCAN coordinates short-term, high-impact support that helps returning citizens stabilize and move forward."
        />
        <p class="max-w-4xl text-base leading-7 text-text-subtle">
          Requests come through the DC Public Defender Service, and congregations in the RCAN
          network mobilize quickly to respond with direct support, coordination, and follow-through.
        </p>
      </article>

      <figure class="overflow-hidden rounded-lg border border-border-default bg-surface-default shadow-lg">
        <Image
          src={supportImage}
          class="h-full w-full object-cover"
          alt="A community mural featuring hands and symbols of shared care, representing collective support for neighbors in transition."
          width={800}
          widths={[320, 480, 568, 640, 720, 800]}
          sizes="(min-width: 1280px) 568px, (min-width: 1024px) calc((100vw - 9rem) / 2), 100vw"
          format="webp"
          quality={55}
          loading="eager"
          priority
        />
      </figure>
    </div>
  </section>

  <section class="py-10" aria-labelledby="help-types-heading">
    <h2 id="help-types-heading" class="section-title text-2xl font-semibold text-text-default">Types of support</h2>
    <ul class="mt-6 grid gap-4 md:grid-cols-2">
      {
        assistanceExamples.map((item) => (
          <li>
            <Card class="group h-full bg-neutral-100 transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
              <p class="flex items-start gap-3 text-base text-text-subtle">
                <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-status-success/15">
                  <Icon
                    name="check"
                    size="sm"
                    class="text-status-success transition-transform duration-base group-hover:scale-110"
                    aria-hidden="true"
                  />
                </span>
                <span>{item}</span>
              </p>
            </Card>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="py-10" aria-labelledby="pathway-heading">
    <h2 id="pathway-heading" class="section-title text-2xl font-semibold text-text-default">Support pathway</h2>
    <ol class="mt-6 grid gap-4 md:grid-cols-3">
      <li>
        <Card class="h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">1. Request received</p>
          <p class="mt-2 text-base text-text-subtle">
            RCAN receives a specific short-term need through trusted referral channels.
          </p>
        </Card>
      </li>
      <li>
        <Card class="h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">2. Congregation response</p>
          <p class="mt-2 text-base text-text-subtle">
            Network congregations coordinate volunteers, resources, and funding support.
          </p>
        </Card>
      </li>
      <li>
        <Card class="h-full transition-transform duration-base hover:-translate-y-1 hover:shadow-md">
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">3. Stabilization</p>
          <p class="mt-2 text-base text-text-subtle">
            Immediate barriers are reduced so individuals can focus on long-term reentry goals.
          </p>
        </Card>
      </li>
    </ol>
  </section>

  <section class="rounded-lg border border-border-default bg-surface-subtle px-6 py-6 text-center md:px-8" aria-labelledby="help-cta-heading">
    <h2 id="help-cta-heading" class="section-title text-2xl font-semibold text-text-default">Join this response network</h2>
    <p class="mx-auto mt-3 max-w-3xl text-base leading-7 text-text-subtle">
      RCAN's impact depends on congregations and supporters who can respond to urgent needs.
    </p>
    <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
      <Button href="/get-involved" variant="secondary" size="md">Get involved</Button>
      <Button href="/donate" variant="primary" size="md">Support RCAN</Button>
    </div>
  </section>
</BaseLayout>