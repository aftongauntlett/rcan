---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import PageHeader from "../components/PageHeader.astro";
import SectionTitle from "../components/SectionTitle.astro";
import IconSupportList from "../components/IconSupportList.astro";
import CTABlock from "../components/CTABlock.astro";
import CountUpScript from "../components/CountUpScript.astro";
import PhotoGallery from "../components/PhotoGallery.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import supportPathwayImage from "../assets/support-pathway.jpg";
import {
  beautyPhotos,
  bikePhotos,
  holidayPhotos,
  pathwaySteps,
  prisonFriendsDo,
} from "../data/howWeHelp";

const pageTitle = "How We Help | RCAN";
const pageDescription =
  "Explore the support pathways and services RCAN coordinates for returning citizens and their families.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section
    aria-labelledby="how-we-help-heading"
    class="border-b border-border-default pb-10 pt-2 md:pb-12"
  >
    <PageHeader id="how-we-help-heading" heading="Practical support when timing matters most" />
  </section>

  <section class="pb-10" aria-labelledby="pathway-heading">
    <SectionTitle id="pathway-heading" text="Support pathway" />
    <div class="mt-6 grid gap-6 lg:grid-cols-[2fr_3fr] lg:items-stretch">
      <figure class="overflow-hidden rounded-lg shadow-md">
        <Image
          src={supportPathwayImage}
          class="h-full w-full object-cover"
          alt="A carved wooden hand propping up a leaning tree branch, symbolizing steady support."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          format="webp"
          quality={60}
          loading="lazy"
        />
      </figure>

      <div class="flex h-full flex-col">
        <p class="text-base leading-7 text-text-subtle">
          Requests come through the DC Public Defender Service. RCAN congregations then coordinate
          practical, short-term support that helps people stabilize quickly and move toward
          longer-term reentry goals. RCAN usually receives 2-3 urgent requests each week.
        </p>
        <ol class="mt-6 space-y-6 border-l-2 border-border-default pl-6">
          {
            pathwaySteps.map((step) => (
              <li>
                <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">
                  {step.label}
                </p>
                <p class="mt-1 text-base leading-7 text-text-subtle">{step.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- Program Highlights -->
  <section
    class="border-t border-border-default space-y-12 md:space-y-16"
    aria-label="Program highlights"
  >
    <!-- Emergency Assistance -->
    <article class="py-10" aria-labelledby="emergency-assistance-heading">
      <SectionTitle id="emergency-assistance-heading" text="Emergency Assistance" level={3} />
      <div class="mt-6 space-y-4">
        <p class="text-base leading-7 text-text-subtle">
          Each week RCAN receives requests to help clients of the Public Defender Service who are
          returning from incarceration. People often are released from prison with little or no
          resources and need help with basics such as food, clothing and emergency shelter. RCAN
          assists these men and women with gift cards to places like Giant Food, Target and CVS
          where they can get the basic necessities for their reentry into the community.
        </p>
        <p class="text-base leading-7 text-text-subtle">
          Congregations in RCAN often collect food and clothing for these individuals to supplement
          what they are able to purchase and also sometimes get donations of furniture to help
          furnish an apartment. Individuals returning to the community also need cell phones they
          can use to help get and keep a job, arrange appointments, and communicate with health
          professionals and so often RCAN will provide a phone as well as prepaid minutes they can
          use.
        </p>
      </div>
    </article>

    <!-- Prison Friendship Project -->
    <section
      id="prison-friendship-project"
      class="border-t border-border-default py-10"
      aria-labelledby="prison-friendship-heading"
    >
      <SectionTitle id="prison-friendship-heading" text="Prison Friendship Project" level={3} />

      <div class="mt-8 grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
        <aside class="flex flex-col" aria-label="Prison Friendship Project highlights">
          <p class="text-base leading-7 text-text-subtle">
            About 4,000 people from Washington, DC are scattered in federal prisons across the
            country. Most are incarcerated hundreds of miles from their families, in conditions of
            isolation and deprivation that are hard to imagine. Many have served long sentences and
            lost contact with family and friends. A human connection from the outside offers hope,
            affirms their humanity, and helps set the stage for successful reentry.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            To increase personal connections between RCAN supporters and DC PDS clients who are
            currently incarcerated, RCAN created the Prison Friendship Project. Any individual — or
            small group — who would like to become a "Prison Friend" will be matched with a PDS
            client serving a sentence in the Bureau of Prisons.
          </p>
          <p class="mt-auto pt-6 text-sm leading-6 text-text-subtle italic">
            RCAN supports Prison Friends with background on the client, access to lawyers and social
            workers, guidelines for writing letters and sending items, and ideas for correspondence.
          </p>
        </aside>

        <div class="flex flex-col">
          <dl class="grid grid-cols-2 gap-3">
            <div
              class="group rounded-lg border border-border-default bg-surface-default px-4 py-4 shadow-sm motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md"
            >
              <dt class="text-xs leading-5 text-text-subtle">New pen pal matches</dt>
              <dd
                class="mt-1 text-3xl font-bold text-brand-primary motion-safe:transition-colors motion-safe:duration-200 group-hover:text-brand-secondary"
              >
                <span
                  class="inline-block min-w-12 tabular-nums"
                  data-count-to="23"
                  data-count-duration="800">23</span
                >
              </dd>
            </div>
            <div
              class="group rounded-lg border border-border-default bg-surface-default px-4 py-4 shadow-sm motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md"
            >
              <dt class="text-xs leading-5 text-text-subtle">Letters being sent now</dt>
              <dd
                class="mt-1 text-3xl font-bold text-brand-primary motion-safe:transition-colors motion-safe:duration-200 group-hover:text-brand-secondary"
              >
                <span
                  class="inline-block min-w-12 tabular-nums"
                  data-count-to="40"
                  data-count-duration="800">40</span
                >
              </dd>
            </div>
          </dl>
          <IconSupportList
            items={prisonFriendsDo}
            columns={1}
            ariaLabel="What Prison Friends do"
            compact
          />
        </div>
      </div>
    </section>

    <!-- Bike Ministry -->
    <section class="border-t border-border-default py-10" aria-labelledby="bike-ministry-heading">
      <SectionTitle id="bike-ministry-heading" text="Bike Ministry" level={3} />
      <div class="mt-6 grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-start">
        <div class="space-y-4">
          <p class="text-base leading-7 text-text-subtle">
            Many people returning from prison need some form of transportation to get around the
            community and one way RCAN meets this need is by providing them with free bicycles. RCAN
            works with Manuel Vera who lives in Silver Spring, Maryland and loves to restore donated
            bicycles and provide them for PDS clients and others who are in need.
          </p>
          <p class="text-base leading-7 text-text-subtle">
            Manny has restored more than 1,000 bicycles through the years and many of those bicycles
            now go to individuals identified by RCAN who use them to get to work, run errands or
            simply for recreation and fun.
          </p>
          <p class="text-base leading-7 text-text-subtle">
            To donate a bike to be refurbished or for more information, email <a
              href="mailto:dcrcan2018@gmail.com"
              class="underline underline-offset-2 hover:text-brand-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default"
              >dcrcan2018@gmail.com</a
            >.
          </p>
        </div>
        <figure class="rounded-lg bg-surface-subtle px-5 py-5">
          <blockquote
            class="border-l-4 border-brand-secondary pl-4 text-base italic leading-7 text-text-default"
          >
            <p>
              "As long as I'm getting bikes and people want bikes, I think I'm going to keep this
              going for quite some time."
            </p>
          </blockquote>
          <figcaption
            class="mt-2 text-right text-sm font-semibold uppercase tracking-wide text-brand-secondary"
          >
            — Manuel Vera
          </figcaption>
        </figure>
      </div>
      <PhotoGallery
        photos={bikePhotos}
        ariaLabel="Bike Ministry photos"
        class="mx-auto max-w-4xl"
        aspectClass="aspect-4/5"
      />
    </section>

    <!-- Beauty Behind Bars -->
    <section
      class="border-t border-border-default py-10"
      aria-labelledby="beauty-behind-bars-heading"
    >
      <SectionTitle
        id="beauty-behind-bars-heading"
        text="Beauty Behind Bars: The Transformative Power of Arts in Confinement"
        level={3}
      />
      <div class="mt-6 grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-start">
        <div class="space-y-4">
          <p class="text-base leading-7 text-text-subtle">
            Hosted at Studio Gallery in January 2025 and curated by Anokhi Shah and LaVander
            Williams, Beauty Behind Bars featured art and poetry by PDS clients, including Fernard
            Strowbridge, Arlis Hicks-Bey, Curtis Dickson, David Watkins, Harry Ellis, Keith Starr,
            and others.
          </p>
          <p class="text-base leading-7 text-text-subtle">
            The exhibit invited audiences to see resilience and humanity beyond incarceration. RCAN
            churches later hosted the collection locally, and PDS attorneys used this context in
            advocacy tied to release efforts under the Incarceration Reduction Amendment Act.
          </p>
          <div class="flex justify-end lg:justify-start">
            <Button
              href="https://www.studiogallerydc.com/beauty-behind-bars-online-catalogue"
              target="_blank"
              rel="noopener noreferrer"
              variant="secondary"
              size="sm"
            >
              View Catalog
              <Icon name="external-link" size="sm" aria-hidden="true" />
            </Button>
          </div>
        </div>
        <figure class="rounded-lg bg-surface-subtle px-5 py-5">
          <blockquote
            class="border-l-4 border-brand-secondary pl-4 text-base italic leading-7 text-text-default"
          >
            <p>
              Tough times do not last, but tough people do. My mantra is positive consistency,
              striving to do right regardless of one's circumstances.
            </p>
          </blockquote>
          <figcaption
            class="mt-2 text-right text-sm font-semibold uppercase tracking-wide text-brand-secondary"
          >
            — Fernard Strowbridge
          </figcaption>
        </figure>
      </div>
      <PhotoGallery
        photos={beautyPhotos}
        ariaLabel="Beauty Behind Bars images"
        class="mx-auto max-w-3xl"
      />
    </section>

    <!-- Holiday Gifts -->
    <article class="border-t border-border-default py-10" aria-labelledby="holiday-story-heading">
      <SectionTitle id="holiday-story-heading" text="Holiday Gifts" level={3} />
      <div class="mt-6 grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-start">
        <div class="space-y-4">
          <p class="text-base leading-7 text-text-subtle">
            Each year at Christmas, RCAN makes a special effort to identify and assist families of
            PDS clients who are in need. For each of the past few years, we have helped ten families
            that each had multiple children with necessities like food and clothing as well as gifts
            for each family member. RCAN Board Member Connie Kurihara has coordinated this program
            with the assistance from members of several congregations.
          </p>
          <p class="text-base leading-7 text-text-subtle">
            In addition, in 2025 RCAN helped provide gifts for 120 juveniles who were detained at
            the Youth Services Center during Christmas. RCAN worked with attorney Kayla Wyatt who
            identified this need and made arrangements for all of the young people to get at least
            one gift.
          </p>
        </div>
        <figure
          class="group rounded-lg bg-surface-subtle px-5 py-6 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md"
        >
          <blockquote
            class="border-l-4 border-brand-secondary pl-4 text-base italic leading-8 text-text-default motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary"
          >
            <p>
              Kayla found a way to make their holiday season just a little better by making every
              kid at YSC feel loved and cared for.
            </p>
          </blockquote>
          <figcaption
            class="mt-3 text-right text-sm font-semibold uppercase tracking-wide text-brand-secondary"
          >
            — DC PDS
          </figcaption>
        </figure>
      </div>
      <PhotoGallery photos={holidayPhotos} ariaLabel="Holiday Gifts photos" />
    </article>
  </section>

  <CTABlock
    heading="Join this response network"
    body="RCAN depends on congregations and supporters who can respond when urgent needs arise."
    primaryLabel="Get involved"
    primaryHref="/get-involved"
    secondaryLabel="Support RCAN"
    secondaryHref="/donate"
  />

  <CountUpScript />
</BaseLayout>
