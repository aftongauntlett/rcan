---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import CTABlock from "../components/CTABlock.astro";
import Button from "../components/Button.astro";
import supportImage from "../assets/art-community.jpg";
import bagOfGiftsImage from "../assets/bag-of-gifts.jpg";
import cakeGiftImage from "../assets/cake-gift.jpg";
import beautyBehindBarsImage from "../assets/beauty-behind-bars.jpg";
import paintingImage from "../assets/painting.jpg";
import bikeGiftsImage from "../assets/bike-gifts.jpg";
import bikeBagsGiftImage from "../assets/bike-bags-gift.jpg";

const pageTitle = "How We Help | RCAN";
const pageDescription =
  "Explore the support pathways and services RCAN coordinates for returning citizens and their families.";

const pathwaySteps = [
  {
    label: "1. Request received",
    body: "RCAN receives a specific short-term need through the DC Public Defender Service. All individuals are people PDS represents or has previously represented.",
  },
  {
    label: "2. Network mobilizes",
    body: "RCAN shares information with the full network. Each congregation determines whether it is able to help with a particular request — then coordinates volunteers, resources, or funding.",
  },
  {
    label: "3. Stabilization",
    body: "Immediate barriers are reduced so individuals can focus on longer-term reentry goals — housing, employment, and community.",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="border-b border-border-default pb-10 pt-6 md:pt-8" aria-label="How We Help overview">
    <SectionHeader
      level={1}
      heading="Practical support when timing matters most"
      subheading="RCAN coordinates short-term, high-impact support that helps returning citizens stabilize and move forward."
    />
    <p class="mt-6 text-base leading-7 text-text-subtle">
      Requests come through the DC Public Defender Service. RCAN congregations then coordinate
      practical, short-term support that helps people stabilize quickly and move toward
      longer-term reentry goals.
    </p>
  </section>

  <section class="py-10" aria-labelledby="pathway-heading">
    <div class="grid gap-6 lg:grid-cols-[2fr_3fr] lg:items-stretch">
      <figure class="overflow-hidden rounded-lg shadow-md">
        <Image
          src={supportImage}
          class="h-full w-full object-cover"
          alt="A community mural featuring hands and symbols of shared care, representing collective support for neighbors in transition."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 40vw, 100vw"
          format="webp"
          quality={60}
          loading="lazy"
        />
      </figure>

      <div class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10">
        <h2 id="pathway-heading" class="section-title text-text-subtle">Support pathway</h2>
        <ol class="mt-6 space-y-6 border-l-2 border-border-default pl-6">
          {
            pathwaySteps.map((step) => (
              <li>
                <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">{step.label}</p>
                <p class="mt-1 text-base leading-7 text-text-subtle">{step.body}</p>
              </li>
            ))
          }
        </ol>
        <p class="mt-6 text-sm text-text-subtle">
          Most weeks, RCAN coordinates one to two urgent requests through the network.
        </p>
        <div class="mt-5 flex justify-end">
          <Button href="/impact" variant="secondary" size="sm">Our Impact</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Highlights -->
  <section class="space-y-12 md:space-y-16" aria-label="Program highlights">

    <article class="py-10" aria-labelledby="holiday-story-heading">
      <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
        <div class="flex flex-col gap-4">
          <figure class="overflow-hidden rounded-lg shadow-md">
            <Image
              src={bagOfGiftsImage}
              class="h-32 w-full object-cover md:h-36 lg:h-40"
              alt="Holiday gift bags prepared for detained youth at the Youth Services Center."
              widths={[320, 480, 640]}
              sizes="(min-width: 1024px) 32vw, 100vw"
              format="webp"
              quality={70}
              loading="lazy"
            />
          </figure>
          <figure class="overflow-hidden rounded-lg shadow-md">
            <Image
              src={cakeGiftImage}
              class="h-32 w-full object-cover brightness-110 contrast-110 md:h-36 lg:h-40"
              alt="Connie holds a birthday cake she delivered to a PDS client."
              widths={[320, 480, 640]}
              sizes="(min-width: 1024px) 32vw, 100vw"
              format="webp"
              quality={70}
              loading="lazy"
            />
            <figcaption class="mt-2 text-center text-xs italic leading-5 text-text-subtle">
              Connie delivers a birthday cake to a PDS client.
            </figcaption>
          </figure>
        </div>

        <div class="flex h-full flex-col">
          <h3 id="holiday-story-heading" class="section-title text-text-subtle">Holiday Gifts at the Youth Services Center</h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            RCAN-supported attorney Kayla Wyatt gave small Christmas gifts to 120 detained juveniles at the Youth Services Center.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            RCAN volunteer Connie marks birthdays and holidays throughout the year, delivering homemade cakes and small celebrations to PDS clients so no one marks the day alone.
          </p>
          <figure class="group mt-5 rounded-lg bg-surface-subtle px-5 py-6 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md lg:mt-auto">
            <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-8 text-text-default motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary">
              <p>
                A lot of the kids at YSC have been away from their families for a long time and, some, are away for the first time during the holiday. I cannot imagine how awful that is. But Kayla found a way to make their holiday season just a little better by making every kid at YSC feel loved and cared for.
              </p>
            </blockquote>
            <figcaption class="mt-3 text-right text-sm text-text-subtle">— DC PDS</figcaption>
          </figure>
        </div>
      </div>
    </article>

    <!-- Beauty Behind Bars -->
    <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="beauty-behind-bars-heading">
      <div class="grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-stretch">
        <div class="flex h-full flex-col">
          <h3 id="beauty-behind-bars-heading" class="section-title text-text-subtle">
            <a
              href="https://www.studiogallerydc.com/beauty-behind-bars-online-catalogue"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 hover:text-brand-accent hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-subtle"
            >
              Beauty Behind Bars: The Transformative Power of Arts in Confinement
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M15 3h6v6" />
                <path d="M10 14 21 3" />
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              </svg>
            </a>
          </h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            Hosted at Studio Gallery in January 2025 and curated by Anokhi Shah and LaVander Williams, Beauty Behind Bars featured art and poetry by PDS clients, including Fernard Strowbridge, Arlis Hicks-Bey, Curtis Dickson, David Watkins, Harry Ellis, Keith Starr, and others.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            The exhibit invited audiences to see resilience and humanity beyond incarceration. RCAN churches later hosted the collection locally, and PDS attorneys used this context in advocacy tied to release efforts under the Incarceration Reduction Amendment Act.
          </p>
          <div class="mt-6">
            <figure class="rounded-lg bg-surface-default px-5 py-5">
              <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-7 text-text-default">
                <p>
                  Tough times do not last, but tough people do. My mantra is positive consistency, striving to do right regardless of one's circumstances.
                </p>
              </blockquote>
              <figcaption class="mt-2 text-right text-sm text-text-subtle">— Fernard Strowbridge</figcaption>
            </figure>
          </div>
        </div>

        <div class="flex h-full flex-col" data-carousel aria-label="Beauty Behind Bars images">
          <div id="beauty-carousel-track" class="group relative h-80 overflow-hidden rounded-lg shadow-sm md:h-96 lg:h-full">
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-100 motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={beautyBehindBarsImage}
                class="h-full w-full object-cover object-top"
                alt="PDS staff, RCAN volunteers, and recently returned clients show their artwork at the Beauty Behind Bars event at St. Columba's Episcopal Church."
                width={600}
                widths={[320, 480, 600]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-0 pointer-events-none motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={paintingImage}
                class="h-full w-full object-cover"
                alt="A recently returned PDS client stands beside his large mural on display at the Beauty Behind Bars exhibition."
                width={600}
                widths={[320, 480, 600]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <div class="absolute inset-x-0 bottom-0 z-10 border-t border-neutral-200/40 bg-surface-invert/80 px-3 py-2 motion-safe:transition-opacity motion-safe:duration-500 motion-safe:ease-out">
              <div class="flex items-center justify-between gap-3">
                <button
                  type="button"
                  data-carousel-prev
                  aria-label="Previous Beauty Behind Bars image"
                  aria-controls="beauty-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent cursor-pointer text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m15 18-6-6 6-6" />
                  </svg>
                </button>
                <p class="text-xs font-semibold tracking-wide text-neutral-100" data-carousel-status aria-live="polite">1 / 2</p>
                <button
                  type="button"
                  data-carousel-next
                  aria-label="Next Beauty Behind Bars image"
                  aria-controls="beauty-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent cursor-pointer text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10" aria-labelledby="bike-ministry-heading">
      <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
        <div class="flex h-full flex-col" data-carousel aria-label="Bike Ministry images">
          <div id="bike-carousel-track" class="group relative h-80 overflow-hidden rounded-lg shadow-sm md:h-96 lg:h-full">
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-100 motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={bikeGiftsImage}
                class="h-full w-full object-cover"
                alt="A restored bicycle prepared for delivery to a returning citizen."
                width={700}
                widths={[320, 480, 700]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-0 pointer-events-none motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={bikeBagsGiftImage}
                class="h-full w-full object-cover"
                alt="A restored bicycle displayed with gift bags prepared by RCAN supporters."
                width={700}
                widths={[320, 480, 700]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <div class="absolute inset-x-0 bottom-0 z-10 border-t border-neutral-200/40 bg-surface-invert/80 px-3 py-2 motion-safe:transition-opacity motion-safe:duration-500 motion-safe:ease-out">
              <div class="flex items-center justify-between gap-3">
                <button
                  type="button"
                  data-carousel-prev
                  aria-label="Previous Bike Ministry image"
                  aria-controls="bike-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent cursor-pointer text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m15 18-6-6 6-6" />
                  </svg>
                </button>
                <p class="text-xs font-semibold tracking-wide text-neutral-100" data-carousel-status aria-live="polite">1 / 2</p>
                <button
                  type="button"
                  data-carousel-next
                  aria-label="Next Bike Ministry image"
                  aria-controls="bike-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent cursor-pointer text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="flex h-full flex-col">
          <h3 id="bike-ministry-heading" class="section-title text-text-subtle">Bike Ministry</h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            Manuel Vera, 74, restores donated bicycles in Silver Spring and gives them to refugees, immigrants, and returning citizens who need dependable transportation for daily use.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            What began as neighborhood tune-ups during the pandemic grew into a word-of-mouth network of donors and recipients. In 2025, he completed his 1,000th restored bike through RCAN-connected requests and continues matching available bikes to community need.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            To donate an unused bike or request more information, email <a href="mailto:manvera@yahoo.com" class="underline underline-offset-2 hover:text-brand-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default">manvera@yahoo.com</a>.
          </p>
          <figure class="mt-8 rounded-lg bg-surface-subtle px-5 py-5 lg:mt-auto">
            <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-7 text-text-default">
              <p>
                "As long as I'm getting bikes and people want bikes, I think I'm going to keep this going for quite some time."
              </p>
            </blockquote>
            <figcaption class="mt-2 text-right text-sm text-text-subtle">- Manuel Vera</figcaption>
          </figure>
        </div>
      </div>
    </section>
  </section>

  <CTABlock
    heading="Join this response network"
    body="RCAN depends on congregations and supporters who can respond when urgent needs arise."
    primaryLabel="Get involved"
    primaryHref="/get-involved"
    secondaryLabel="Support RCAN"
    secondaryHref="/donate"
    variant="outline"
  />

  <script>
    import { initCarousels } from "../utils/carousel";

    initCarousels();
    document.addEventListener("astro:page-load", () => initCarousels());
  </script>
</BaseLayout>