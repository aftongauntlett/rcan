---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import supportImage from "../assets/art-community.jpg";

const pageTitle = "How We Help | RCAN";
const pageDescription =
  "Explore the support pathways and services RCAN coordinates for returning citizens and their families.";

const assistanceExamples = [
  "Help finding or furnishing an apartment, or paying an application fee or security deposit",
  "Free food, clothing, and items for personal hygiene",
  "Transportation assistance — Metro cards, free bicycles, Uber rides",
  "Funds to avoid eviction or help with other emergency financial needs, including utilities",
  "Assistance looking for work and/or learning job skills",
  "Informal life-skills counseling or personal mentoring",
  "Sending books to incarcerated clients",
  "Assisting with costs for juveniles to participate in therapeutic programs as part of release conditions",
  "Court-imposed fees and sanctions that clients cannot afford to pay",
  "Providing a letter of support for clients seeking release under the Incarceration Reduction Amendment Act",
  "Green card fees, therapy sessions, and cellphones to keep in contact with attorneys and find work",
];

const pathwaySteps = [
  {
    label: "1. Request received",
    body: "RCAN receives a specific short-term need through the DC Public Defender Service. All individuals are people PDS represents or has previously represented.",
  },
  {
    label: "2. Network mobilizes",
    body: "RCAN shares information with the full network. Each congregation determines whether it is able to help with a particular request — then coordinates volunteers, resources, or funding.",
  },
  {
    label: "3. Stabilization",
    body: "Immediate barriers are reduced so individuals can focus on longer-term reentry goals — housing, employment, and community.",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="py-10 md:py-14" aria-label="How We Help overview">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-stretch">
      <article class="flex h-full flex-col gap-6">
        <SectionHeader
          level={1}
          heading="Practical support when timing matters most"
          subheading="RCAN coordinates short-term, high-impact support that helps returning citizens stabilize and move forward."
        />
        <p class="text-base leading-7 text-text-subtle">
          Requests come through the DC Public Defender Service, and congregations in the RCAN
          network mobilize quickly to respond with direct support, coordination, and follow-through.
        </p>
      </article>

      <figure class="overflow-hidden rounded-lg shadow-lg">
        <Image
          src={supportImage}
          class="h-full min-h-80 w-full object-cover"
          alt="A community mural featuring hands and symbols of shared care, representing collective support for neighbors in transition."
          width={900}
          widths={[360, 540, 720, 900]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          format="webp"
          quality={60}
          loading="eager"
          priority
        />
      </figure>
    </div>
  </section>

  <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="help-types-heading">
    <h2 id="help-types-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Types of support</h2>
    <ul class="mt-6 columns-1 gap-x-12 sm:columns-2" aria-label="Types of assistance RCAN provides">
      {
        assistanceExamples.map((item) => (
          <li class="flex items-start gap-3 break-inside-avoid py-2 text-base leading-7 text-text-subtle">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-secondary" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="py-10" aria-labelledby="pathway-heading">
    <h2 id="pathway-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Support pathway</h2>
    <ol class="mt-6 space-y-6 border-l-2 border-border-default pl-6">
      {
        pathwaySteps.map((step) => (
          <li>
            <p class="text-sm font-semibold uppercase tracking-wide text-brand-secondary">{step.label}</p>
            <p class="mt-1 text-base leading-7 text-text-subtle">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="rounded-lg bg-surface-subtle px-6 py-8 text-center md:px-8 md:py-10" aria-labelledby="help-cta-heading">
    <h2 id="help-cta-heading" class="text-xl font-semibold text-text-default">Join this response network</h2>
    <p class="mx-auto mt-3 max-w-3xl text-base leading-7 text-text-subtle">
      RCAN's impact depends on congregations and supporters who can respond to urgent needs.
    </p>
    <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
      <Button href="/get-involved" variant="secondary" size="md">Get involved</Button>
      <Button href="/donate" variant="primary" size="md">Support RCAN</Button>
    </div>
  </section>
</BaseLayout>