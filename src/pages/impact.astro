---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import CTABlock from "../components/CTABlock.astro";
import StatStrip from "../components/StatStrip.astro";
import beautyBehindBarsImage from "../assets/beauty-behind-bars.jpg";
import paintingImage from "../assets/painting.jpg";
import cakeGiftImage from "../assets/cake-gift.jpg";
import bagOfGiftsImage from "../assets/bag-of-gifts.jpg";
import bikeGiftsImage from "../assets/bike-gifts.jpg";
import bikeBagsGiftImage from "../assets/bike-bags-gift.jpg";
import giveImage from "../assets/give.jpg";

const pageTitle = "Impact | RCAN";
const pageDescription =
  "2025 highlights showing the range of support RCAN provides — stories, quotes, and program updates from the Returning Citizens Assistance Network.";

const impactStats = [
  { value: "361", label: "clients supported in 2025" },
  { prefix: "$", value: "15,325", label: "in gift cards provided" },
  { value: "120", label: "detained juveniles received holiday gifts" },
  { value: "1,000th", label: "bicycle serviced and donated in 2025" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- Hero -->
  <section class="border-b border-border-default pb-10 pt-10 md:pt-14" aria-labelledby="impact-heading">
    <SectionHeader
      id="impact-heading"
      level={1}
      heading="2025 Impact Highlights"
    />
    <p class="mt-6 text-base leading-7 text-text-subtle">
      These highlights show the range of support RCAN provides — stories, program updates, and
      results from the past year. Whether through monetary or household donations, the gift of
      time, or sustained personal relationships with PDS clients, the network continues to help
      more people than ever before.
    </p>
    <p class="mt-4 text-base leading-7 text-text-subtle">
      The highlights below show personal stories, program milestones, and practical outcomes across the network, including $15,325 in gift cards and material support for food insecurity, eviction risk, utility bills, clothing, funeral costs, car repairs, restitution, and professional fees.
    </p>
  </section>

  <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="numbers-heading">
    <h2 id="numbers-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">
      2025 by the numbers
    </h2>
    <div class="mt-6">
      <StatStrip
        stats={impactStats}
        layout="grid"
        background="subtle"
        accentColor="primary"
        hoverSwapAccent
      />
    </div>
    <p class="mx-auto mt-3 max-w-4xl text-center text-sm leading-6 text-text-subtle">
      Together, these milestones show how practical support, trusted relationships, and rapid response shaped outcomes across the network.
    </p>
  </section>

  <!-- Program Highlights -->
  <section class="space-y-12 md:space-y-16" aria-label="Program highlights">

    <article class="py-10" aria-labelledby="holiday-story-heading">
      <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
        <figure class="overflow-hidden rounded-lg shadow-md">
          <Image
            src={bagOfGiftsImage}
            class="h-56 w-full object-cover sm:h-64 md:h-72 lg:h-80"
            alt="Holiday gift bags prepared for detained youth at the Youth Services Center."
            widths={[320, 480, 640]}
            sizes="(min-width: 1024px) 32vw, 100vw"
            format="webp"
            quality={70}
            loading="lazy"
          />
        </figure>

        <div class="flex h-full flex-col">
          <h3 id="holiday-story-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Holiday Gifts at the Youth Services Center</h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            RCAN-supported attorney Kayla Wyatt gave small Christmas gifts to 120 detained juveniles at the Youth Services Center.
          </p>
          <figure class="group mt-5 rounded-lg bg-surface-subtle px-5 py-6 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md lg:mt-auto">
            <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-8 text-text-default motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary">
              <p>
                A lot of the kids at YSC have been away from their families for a long time and, some, are away for the first time during the holiday. I cannot imagine how awful that is. But Kayla found a way to make their holiday season just a little better by making every kid at YSC feel loved and cared for.
              </p>
            </blockquote>
            <figcaption class="mt-3 text-right text-sm text-text-subtle">— DC PDS</figcaption>
          </figure>
        </div>
      </div>
    </article>

    <!-- Beauty Behind Bars -->
    <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="beauty-behind-bars-heading">
      <div class="grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-stretch">
        <div class="flex h-full flex-col">
          <h3 id="beauty-behind-bars-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">
            <a
              href="https://www.studiogallerydc.com/beauty-behind-bars-online-catalogue"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 hover:text-brand-accent hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-subtle"
            >
              Beauty Behind Bars: The Transformative Power of Arts in Confinement
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M15 3h6v6" />
                <path d="M10 14 21 3" />
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              </svg>
            </a>
          </h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            Hosted at Studio Gallery in January 2025 and curated by Anokhi Shah and LaVander Williams, Beauty Behind Bars featured visual art and poetry by PDS clients, including Fernard Strowbridge, Arlis Hicks-Bey, Curtis Dickson, David Watkins, Harry Ellis, Keith Starr, and others.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            The exhibit invited audiences to see resilience and humanity beyond incarceration. RCAN churches later hosted the collection locally, and PDS attorneys used this context in advocacy tied to release efforts under the Incarceration Reduction Amendment Act.
          </p>
          <div class="mt-6">
            <figure class="rounded-lg bg-surface-default px-5 py-5">
              <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-7 text-text-default">
                <p>
                  Tough times do not last, but tough people do. My mantra is positive consistency, striving to do right regardless of one's circumstances.
                </p>
              </blockquote>
              <figcaption class="mt-2 text-right text-sm text-text-subtle">— Fernard Strowbridge</figcaption>
            </figure>
          </div>
        </div>

        <div class="flex h-full flex-col" data-carousel aria-label="Beauty Behind Bars images">
          <div id="beauty-carousel-track" class="group relative h-80 overflow-hidden rounded-lg shadow-sm md:h-96">
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-100 motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={beautyBehindBarsImage}
                class="h-full w-full object-cover object-top"
                alt="PDS staff, RCAN volunteers, and recently returned clients show their artwork at the Beauty Behind Bars event at St. Columba's Episcopal Church."
                width={600}
                widths={[320, 480, 600]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-0 pointer-events-none motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={paintingImage}
                class="h-full w-full object-cover"
                alt="A recently returned PDS client stands beside his large mural on display at the Beauty Behind Bars exhibition."
                width={600}
                widths={[320, 480, 600]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <div class="absolute inset-x-0 bottom-0 z-10 border-t border-neutral-200/40 bg-surface-invert/80 px-3 py-2 motion-safe:transition-opacity motion-safe:duration-500 motion-safe:ease-out md:pointer-events-none md:opacity-0 md:group-hover:pointer-events-auto md:group-hover:opacity-100 md:group-focus-within:pointer-events-auto md:group-focus-within:opacity-100">
              <div class="flex items-center justify-between gap-3">
                <button
                  type="button"
                  data-carousel-prev
                  aria-label="Previous Beauty Behind Bars image"
                  aria-controls="beauty-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m15 18-6-6 6-6" />
                  </svg>
                </button>
                <p class="text-xs font-semibold tracking-wide text-neutral-100" data-carousel-status aria-live="polite">1 / 2</p>
                <button
                  type="button"
                  data-carousel-next
                  aria-label="Next Beauty Behind Bars image"
                  aria-controls="beauty-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10" aria-labelledby="bike-ministry-heading">
      <div class="grid gap-8 lg:grid-cols-[2fr_3fr] lg:items-stretch">
        <div class="flex h-full flex-col" data-carousel aria-label="Bike Ministry images">
          <div id="bike-carousel-track" class="group relative h-80 overflow-hidden rounded-lg shadow-sm md:h-96">
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-100 motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={bikeGiftsImage}
                class="h-full w-full object-cover"
                alt="A restored bicycle prepared for delivery to a returning citizen."
                width={700}
                widths={[320, 480, 700]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <figure data-carousel-slide class="absolute inset-0 h-full opacity-0 pointer-events-none motion-safe:transition-opacity motion-safe:duration-300 motion-safe:ease-out">
              <Image
                src={bikeBagsGiftImage}
                class="h-full w-full object-cover"
                alt="A restored bicycle displayed with gift bags prepared by RCAN supporters."
                width={700}
                widths={[320, 480, 700]}
                sizes="(min-width: 1024px) 32vw, 100vw"
                format="webp"
                quality={65}
                loading="lazy"
              />
            </figure>
            <div class="absolute inset-x-0 bottom-0 z-10 border-t border-neutral-200/40 bg-surface-invert/80 px-3 py-2 motion-safe:transition-opacity motion-safe:duration-500 motion-safe:ease-out md:pointer-events-none md:opacity-0 md:group-hover:pointer-events-auto md:group-hover:opacity-100 md:group-focus-within:pointer-events-auto md:group-focus-within:opacity-100">
              <div class="flex items-center justify-between gap-3">
                <button
                  type="button"
                  data-carousel-prev
                  aria-label="Previous Bike Ministry image"
                  aria-controls="bike-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m15 18-6-6 6-6" />
                  </svg>
                </button>
                <p class="text-xs font-semibold tracking-wide text-neutral-100" data-carousel-status aria-live="polite">1 / 2</p>
                <button
                  type="button"
                  data-carousel-next
                  aria-label="Next Bike Ministry image"
                  aria-controls="bike-carousel-track"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-sm bg-transparent text-text-invert transition-colors duration-base hover:text-neutral-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-invert disabled:cursor-not-allowed disabled:opacity-60"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="flex h-full flex-col">
          <h3 id="bike-ministry-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Bike Ministry</h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            Manuel Vera, 74, restores donated bicycles in Silver Spring and gives them to refugees, immigrants, and returning citizens who need dependable transportation for daily use.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            What began as neighborhood tune-ups during the pandemic grew into a word-of-mouth network of donors and recipients. In 2025, he completed his 1,000th restored bike through RCAN-connected requests and continues matching available bikes to community need.
          </p>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            To donate an unused bike or request more information, email <a href="mailto:manvera@yahoo.com" class="underline underline-offset-2 hover:text-brand-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-surface-default">manvera@yahoo.com</a>.
          </p>
          <figure class="mt-4 rounded-lg bg-surface-subtle px-5 py-5 lg:mt-auto">
            <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-7 text-text-default">
              <p>
                "As long as I'm getting bikes and people want bikes, I think I'm going to keep this going for quite some time."
              </p>
            </blockquote>
            <figcaption class="mt-2 text-right text-sm text-text-subtle">- Manuel Vera</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="second-chance-heading">
      <div class="grid gap-8 lg:grid-cols-[3fr_2fr] lg:items-stretch">
        <div class="flex h-full flex-col">
          <h3 id="second-chance-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Second Chance Event</h3>
          <p class="mt-3 text-base leading-7 text-text-subtle">
            At DC PDS's April Second Chance event, RCAN donated funds and staffed a table to recruit new Prison Friendship Project pen pals and connect with community partners. The event created opportunities for direct conversations with justice-impacted community members, attorneys, and volunteers about immediate reentry barriers and practical support pathways. It also helped expand awareness of RCAN's coordinated response model and strengthen collaboration with organizations already serving returning citizens.
          </p>
          <div class="mt-5 flex justify-end lg:mt-auto">
            <Button
              href="https://secondchanceinc.org/"
              target="_blank"
              rel="noopener noreferrer"
              ariaLabel="Visit Second Chance (opens in a new tab)"
              variant="secondary"
              size="sm"
              class="group"
            >
              Visit Second Chance
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="hidden group-hover:block group-focus-visible:block"
              >
                <path d="M15 3h6v6" />
                <path d="M10 14 21 3" />
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              </svg>
            </Button>
          </div>
        </div>

        <figure class="overflow-hidden rounded-lg shadow-md">
          <Image
            src={giveImage}
            class="h-56 w-full object-cover sm:h-64 md:h-72 lg:h-80"
            alt="Community members joining hands in support at a local event."
            width={900}
            widths={[360, 540, 720, 900]}
            sizes="(min-width: 1024px) 38vw, 100vw"
            format="webp"
            quality={65}
            loading="lazy"
          />
        </figure>
      </div>
    </section>
  </section>

  <section class="border-t border-border-default pt-10" aria-label="Story highlights">
    <div class="flex flex-col gap-10">
      <article class="rounded-lg bg-surface-default px-6 py-8 md:px-8 md:py-10" aria-labelledby="mr-e-heading">
        <div class="flex h-full flex-col">
          <h3 id="mr-e-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Mr. E. — The Most Joyful Man</h3>
          <figure class="group mt-5 rounded-lg bg-surface-subtle px-5 py-6 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md">
            <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-8 text-text-default motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary">
              <p>
                His time at the hotel has been invaluable. It has allowed him to experience the dignity of getting back on his feet with a hot shower, clean bed, and free coffee in the morning — something he has not had for months. For his team, it has allowed us to focus on all the collateral needs he has, which would otherwise be barriers to housing: things like getting him connected with a core services agency, obtaining copies of his birth certificate, and tracking down verification of disability benefit. He walks with a cane and despite an extraordinarily difficult life fraught with poverty, addiction, and homelessness, Mr. E is the most joyful man to be around.
              </p>
            </blockquote>
            <figcaption class="mt-3 text-right text-sm text-text-subtle">— PDS Lawyer</figcaption>
          </figure>
        </div>
      </article>

      <article class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="davenport-story-heading">
        <h3 id="davenport-story-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Ms. Davenport's Birthday</h3>
        <div class="mt-5 grid gap-8 lg:grid-cols-[9fr_3fr] lg:items-start">
          <div class="flex flex-col gap-4">
              <figure class="group rounded-lg bg-surface-default px-5 py-5 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md">
                <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-8 text-text-default motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary">
                  <p>
                    This is so wonderful! Thank you, Kay! I spoke with Ms. Davenport today, and I can tell how much your friendship and support mean to her. And that birthday cake both looked and sounded amazing!
                  </p>
                </blockquote>
                <figcaption class="mt-3 text-right text-sm text-text-subtle">— Florence Bryan, PDS Lawyer</figcaption>
              </figure>

              <figure class="group rounded-lg bg-surface-default px-5 py-5 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md">
                <blockquote class="border-l-4 border-brand-secondary pl-4 text-base italic leading-8 text-text-default motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary">
                  <p>
                    Florence, it is my pleasure to be a friend of Ms. Davenport. I enjoy my time with her. They are wonderful people. Ms. Davenport is very grateful for what you do for her and her family.
                  </p>
                </blockquote>
                <figcaption class="mt-3 text-right text-sm text-text-subtle">— Kay Tatum, RCAN Member</figcaption>
              </figure>
          </div>

          <div>
            <figure class="overflow-hidden rounded-lg shadow-md">
              <Image
                src={cakeGiftImage}
                alt="An RCAN volunteer holds a birthday cake prepared for Ms. Davenport, a PDS client."
                class="h-44 w-full object-cover brightness-110 contrast-110 sm:h-52 md:h-56 lg:h-64"
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 24vw, 100vw"
                format="webp"
                quality={70}
                loading="lazy"
              />
            </figure>
            <p class="mt-2 text-center text-xs italic leading-5 text-text-subtle">
              An RCAN volunteer delivered a birthday cake to a PDS client.
            </p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- CTA -->
  <CTABlock
    variant="fill"
    heading="Help shape next year's impact."
    body="Donations meet urgent needs. Volunteers build lasting relationships. Join the network that responds when timing matters most."
    primaryLabel="Donate"
    primaryHref="/donate"
    secondaryLabel="Get involved"
    secondaryHref="/get-involved"
  />

  <script>
    const carousels = document.querySelectorAll("[data-carousel]");

    carousels.forEach((carousel) => {
      const slides = Array.from(carousel.querySelectorAll("[data-carousel-slide]"));
      const prevButton = carousel.querySelector("[data-carousel-prev]");
      const nextButton = carousel.querySelector("[data-carousel-next]");
      const status = carousel.querySelector("[data-carousel-status]");

      if (
        !(prevButton instanceof HTMLButtonElement) ||
        !(nextButton instanceof HTMLButtonElement) ||
        !(status instanceof HTMLElement) ||
        slides.length === 0
      ) {
        return;
      }

      let currentIndex = 0;

      const render = () => {
        slides.forEach((slide, index) => {
          if (!(slide instanceof HTMLElement)) {
            return;
          }

          const isActive = index === currentIndex;
          slide.classList.toggle("opacity-100", isActive);
          slide.classList.toggle("opacity-0", !isActive);
          slide.classList.toggle("pointer-events-none", !isActive);
          slide.setAttribute("aria-hidden", String(!isActive));
        });

        status.textContent = `${currentIndex + 1} / ${slides.length}`;
      };

      prevButton.addEventListener("click", () => {
        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
        render();
      });

      nextButton.addEventListener("click", () => {
        currentIndex = (currentIndex + 1) % slides.length;
        render();
      });

      render();
    });
  </script>

</BaseLayout>
