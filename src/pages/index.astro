---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";

const pageTitle = "RCAN | Returning Citizens Assistance Network";
const pageDescription =
	"Learn about RCAN and its mission to support returning citizens through community partnerships across Washington, DC.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<SectionHeader
		level={1}
		eyebrow="RCAN"
		heading="Returning Citizens Assistance Network"
		subheading="Homepage content is coming soon."
	/>
</BaseLayout>
