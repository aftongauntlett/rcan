---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import StatStrip from "../components/StatStrip.astro";
import CTABlock from "../components/CTABlock.astro";
import StoryBlock from "../components/StoryBlock.astro";
import BulletList from "../components/BulletList.astro";

import heroImage from "../assets/hands-holding.jpg";

const pageTitle = "RCAN | Returning Citizens Assistance Network";
const pageDescription =
	"RCAN is a Washington, DC network of congregations that responds to urgent short-term needs for returning citizens through direct community support.";

const assistanceExamples = [
	"Providing clothing, food, and personal essentials to people newly released",
	"Offering life-skills counseling and short-term mentoring relationships",
	"Helping secure housing — application fees, security deposits, and furnishings",
	"Collecting and delivering donated furniture for newly housed clients",
	"Providing emergency funds to prevent eviction or meet urgent financial needs",
	"Connecting clients to employers and navigating job applications together",
];

const impactStats = [
	{ value: "361", label: "clients helped in 2025" },
	{ prefix: "$", value: "25,000+", label: "contributed to the RCAN Fund in 2025" },
	{ value: "20", label: "participating congregations" },
	{ value: "40", label: "active Prison Friendship matches" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="py-10 md:py-14" aria-label="About RCAN">
		<div class="grid gap-10 lg:grid-cols-2 lg:items-stretch">
			<!-- Image LEFT -->
			<figure class="overflow-hidden rounded-lg shadow-lg">
				<Image
					src={heroImage}
					class="h-full min-h-80 w-full object-cover"
					alt="A circle of people placing their hands together to show shared support and community solidarity."
					width={900}
					widths={[360, 540, 720, 900]}
					sizes="(min-width: 1024px) 50vw, 100vw"
					format="webp"
					quality={60}
					loading="eager"
					priority
				/>
			</figure>

			<!-- Text + buttons RIGHT -->
			<article class="flex h-full flex-col gap-6">
				<SectionHeader
					level={1}
					heading="Returning Citizens Assistance Network"
					subheading="A Washington, DC network of congregations responding to urgent short-term needs for returning citizens and others involved in the criminal justice system."
				/>
				<p class="text-base leading-7 text-text-subtle">
					Inspired by Bryan Stevenson's call to get proximate to the poor and the incarcerated,
					New York Avenue Presbyterian Church and Metropolitan AME Church partnered with the
					DC Public Defender Service in 2018 to establish RCAN — an informal network of
					congregations committed to social justice and practical support.
				</p>
				<div class="mt-auto flex flex-wrap items-center justify-end gap-3">
				<Button href="/donate" variant="primary" size="md">
					Donate
					</Button>
					<Button href="/how-we-help" variant="secondary" size="md">
						See how RCAN helps
					</Button>
				</div>
			</article>
		</div>

		<!-- Stats row below hero -->
		<div class="mt-10">
			<StatStrip stats={impactStats} layout="grid" background="subtle" />
		</div>
	</section>

	<section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="assistance-heading">
		<h2 id="assistance-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">How RCAN assists</h2>
		<BulletList items={assistanceExamples} columns={2} />
		<div class="mt-6 flex justify-end">
			<Button href="/how-we-help" variant="secondary" size="md">Learn more</Button>
		</div>
	</section>

	<section aria-labelledby="impact-quote-heading">
		<h2 id="impact-quote-heading" class="sr-only">A recent impact</h2>
		<StoryBlock
			heading="A family reunited"
			level={3}
			background="none"
			quotes={[
				{
					text: "Thank you all for your help in supporting TW and his family. All of your donations went such a long way to relieving the stress and anxiety of TW. He is safely with his grandparents that love and care for him. Their immediate burdens have been relieved thanks to the assistance of you all. I cannot express to you the joy this has brought to this family. Thank you all again so much!",
					attribution: "— PDS Lawyer, on behalf of a client's family",
				},
			]}
		/>
	</section>

	<section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="pfp-teaser-heading">
		<h2 id="pfp-teaser-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Prison Friendship Project</h2>
		<p class="mt-3 text-base leading-7 text-text-subtle">
			About 4,000 people from Washington, DC are scattered across federal prisons. The Prison
			Friendship Project matches RCAN supporters with DC clients to build human connection
			across distance.
		</p>
		<div class="mt-6 flex justify-end">
			<Button href="/get-involved#prison-friendship-project" variant="primary" size="md">Become a Prison Friend</Button>
		</div>
	</section>

	<CTABlock
		heading="Support this ministry"
		body="You can make a direct impact for returning citizens in Washington, DC. Every gift helps RCAN respond quickly to urgent needs."
		primaryLabel="Donate"
		primaryHref="/donate"
		secondaryLabel="Get involved"
		secondaryHref="/get-involved"
		background="subtle"
	/>
</BaseLayout>
