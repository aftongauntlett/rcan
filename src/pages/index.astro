---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import StatStrip from "../components/StatStrip.astro";
import CTABlock from "../components/CTABlock.astro";
import IconSupportList from "../components/IconSupportList.astro";
import { Heart } from "@lucide/astro";
import heroImage from "../assets/hands-holding.jpg";

const pageTitle = "RCAN | Returning Citizens Assistance Network";
const pageDescription =
	"RCAN is a Washington, DC network of congregations that responds to urgent short-term needs for returning citizens through direct community support.";

const assistanceExamples = [
	{ icon: "heart" as const, text: "Providing clothing, food, and personal essentials to people newly released" },
	{ icon: "users" as const, text: "Offering life-skills counseling and short-term mentoring relationships" },
	{ icon: "home" as const, text: "Helping secure housing — application fees, security deposits, and furnishings" },
	{ icon: "map-pin" as const, text: "Collecting and delivering donated furniture for newly housed clients" },
	{ icon: "dollar-sign" as const, text: "Providing emergency funds to prevent eviction or meet urgent financial needs" },
	{ icon: "book-open" as const, text: "Connecting clients to employers and navigating job applications together" },
] as const;

const actionItems = [
	{ icon: "check" as const, label: "Fund urgent needs", text: "Every gift goes directly to urgent client needs — housing, food, emergency funds, and more.", cta: { label: "Donate", href: "/donate" } },
	{ icon: "check" as const, label: "Serve in person", text: "Respond to specific client requests with goods, services, or time. Open to all — no congregation required.", cta: { label: "Support", href: "/get-involved" } },
	{ icon: "check" as const, label: "Bring your congregation", text: "If your congregation is in the DC, MD, or VA area, RCAN welcomes new partners committed to social justice.", cta: { label: "Partner", href: "/get-involved" } },
] as const;

const impactStats = [
	{ value: "361", label: "Clients helped in 2025" },
	{ prefix: "$", value: "25,000+", label: "Contributed to the RCAN Fund in 2025" },
	{ value: "20", label: "Participating Congregations" },
	{ value: "40", label: "Active Prison Friendship Matches" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="pt-6 md:pt-8" aria-label="About RCAN">
		<div class="grid gap-10 lg:grid-cols-2 lg:items-stretch">
			<!-- Image LEFT -->
			<figure class="overflow-hidden rounded-lg shadow-lg">
				<Image
					src={heroImage}
					class="h-full min-h-80 w-full object-cover"
					alt="A circle of people placing their hands together to show shared support and community solidarity."
					width={900}
					widths={[360, 540, 720, 900]}
					sizes="(min-width: 1024px) 50vw, 100vw"
					format="webp"
					quality={60}
					loading="eager"
					priority
				/>
			</figure>

			<!-- Text + buttons RIGHT -->
			<article class="flex h-full flex-col gap-6">
				<SectionHeader
					level={1}
					heading="Returning Citizens Assistance Network"
					subheading="RCAN responds to urgent needs for returning citizens and others in the criminal justice system - all referred by the DC Public Defender Service. The network focuses on practical barriers to reentry: housing, clothing, food, employment, and ongoing personal support."
				/>
				<p class="text-base leading-7 text-text-subtle">
					In 2018, inspired by Bryan Stevenson's call to get proximate to those who are
					incarcerated, New York Avenue Presbyterian Church and Metropolitan AME Church
					partnered with the DC Public Defender Service to establish RCAN - an informal
					network of congregations committed to social justice and practical help.
				</p>
				<div class="mt-auto flex flex-wrap items-center justify-end gap-3">
					<Button href="/donate" variant="primary" size="md">Donate today</Button>
					<Button href="/how-we-help" variant="secondary" size="md">How RCAN helps</Button>
				</div>
				<p class="mt-4 text-right text-xs italic text-text-subtle" aria-hidden="true">
					"I was in prison and you came to visit me." - Matthew 25:36
				</p>
			</article>
		</div>

		<!-- Stats row below hero -->
		<div class="mt-10">
			<StatStrip stats={impactStats} layout="grid" background="subtle" accentColor="primary" hoverSwapAccent />
		</div>
	</section>

	<section class="mt-6! rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="assistance-heading">
		<h2 id="assistance-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">How RCAN assists</h2>
		<p class="mt-6 text-base leading-7 text-text-subtle">
			RCAN responds to urgent reentry needs through direct referrals and coordinated support from partner congregations.
			The examples below show how assistance is delivered and where people can step in to help.
		</p>

		<IconSupportList items={assistanceExamples} ariaLabel="Ways RCAN assists returning citizens" columns={2} />
	</section>

	<section class="group grid gap-6 lg:grid-cols-[1fr_280px] lg:items-center" aria-labelledby="how-to-help-heading">
		<div>
			<h2 id="how-to-help-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">How you can help</h2>
			<p class="mt-2 text-sm leading-6 text-text-subtle">Donate, volunteer, or join as a congregation partner in the DC area.</p>
			<IconSupportList items={actionItems} ordered columns={1} ariaLabel="Ways to help RCAN" ctaButton />
		</div>
		<div class="hidden lg:flex items-center justify-center" aria-hidden="true">
			<div class="relative flex h-48 w-48 items-center justify-center">
				<span class="ring-outer absolute inset-0 rounded-full border border-brand-secondary"></span>
				<span class="ring-middle absolute inset-8 rounded-full border border-brand-secondary"></span>
				<span class="ring-inner absolute inset-16 rounded-full bg-brand-secondary"></span>
				<Heart class="icon-heart relative z-10 h-10 w-10 text-brand-secondary" aria-hidden="true" role="presentation" focusable="false" />
			</div>
		</div>
	</section>

	<section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="pfp-teaser-heading" data-fade>
		<h2 id="pfp-teaser-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Prison Friendship Project</h2>
		<p class="mt-3 text-base leading-7 text-text-subtle">
			About 4,000 people from Washington, DC are scattered across federal prisons. The Prison
			Friendship Project matches RCAN supporters with DC clients to build human connection
			across distance. RCAN provides match guidance, client background, and access to social
			workers and attorneys throughout the friendship.
		</p>
		<div class="mt-6 flex flex-wrap items-center justify-between gap-4">
			<dl class="flex gap-8">
				<div aria-label="23 new Prison Friendship matches in 2025">
					<dd class="text-2xl font-bold text-brand-secondary">23</dd>
					<dt class="mt-0.5 text-xs text-text-subtle">new matches in 2025</dt>
				</div>
				<div aria-label="40 active Prison Friendship matches">
					<dd class="text-2xl font-bold text-brand-secondary">40</dd>
					<dt class="mt-0.5 text-xs text-text-subtle">active matches</dt>
				</div>
			</dl>
			<Button href="/get-involved#prison-friendship-project" variant="primary" size="md">Become a Prison Friend</Button>
		</div>
	</section>

	<CTABlock
		variant="outline"
		heading="Stand with returning citizens."
		body="Donations fund emergency needs. Volunteers build connections. Every contribution - of any kind - makes a difference."
		primaryLabel="Donate"
		primaryHref="/donate"
		secondaryLabel="Get involved"
		secondaryHref="/get-involved"
	/>

	<script>
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		if (!reduceMotion) {
			const fadeTargets = document.querySelectorAll("[data-fade]");
			fadeTargets.forEach((target) => {
				target.classList.add("opacity-0");
			});

			const fadeObserver = new IntersectionObserver(
				(entries, observer) => {
					entries.forEach((entry) => {
						if (!entry.isIntersecting) {
							return;
						}

						entry.target.classList.remove("opacity-0");
						entry.target.classList.add("opacity-100", "transition-opacity", "duration-300");
						observer.unobserve(entry.target);
					});
				},
				{ threshold: 0.1 },
			);

			fadeTargets.forEach((target) => {
				fadeObserver.observe(target);
			});
		}
	</script>

	<style>
		/* Fallback opacity — applies in all motion contexts */
		.ring-outer { opacity: 0.1; }
		.ring-middle { opacity: 0.2; }
		.ring-inner { opacity: 0.1; }
		.icon-heart { opacity: 0.35; }

		/* Breathing animation — disabled automatically by global.css when prefers-reduced-motion: reduce */
		@media (prefers-reduced-motion: no-preference) {
			@keyframes breathe-outer  { 0%, 100% { opacity: 0.1; } 50% { opacity: 0.4; } }
			@keyframes breathe-middle { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.6; } }
			@keyframes breathe-inner  { 0%, 100% { opacity: 0.1; } 50% { opacity: 0.3; } }
			@keyframes breathe-heart  { 0%, 100% { opacity: 0.35; } 50% { opacity: 0.85; } }

			.ring-outer  { animation: breathe-outer  3s ease-in-out          infinite; animation-play-state: paused; }
			.ring-middle { animation: breathe-middle 3s ease-in-out 0.7s      infinite; animation-play-state: paused; }
			.ring-inner  { animation: breathe-inner  3s ease-in-out 1.4s      infinite; animation-play-state: paused; }
			.icon-heart  { animation: breathe-heart  3s ease-in-out 0.35s     infinite; animation-play-state: paused; }

			.group:hover .ring-outer,
			.group:hover .ring-middle,
			.group:hover .ring-inner,
			.group:hover .icon-heart { animation-play-state: running; }
		}
	</style>
</BaseLayout>
