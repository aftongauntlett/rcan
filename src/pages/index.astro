---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import StatStrip from "../components/StatStrip.astro";
import CTABlock from "../components/CTABlock.astro";
import BulletList from "../components/BulletList.astro";
import Icon from "../components/Icon.astro";
import gardeningCommunityImage from "../assets/gardening-community.jpg";

import heroImage from "../assets/hands-holding.jpg";

const pageTitle = "RCAN | Returning Citizens Assistance Network";
const pageDescription =
	"RCAN is a Washington, DC network of congregations that responds to urgent short-term needs for returning citizens through direct community support.";

const assistanceExamples = [
	"Providing clothing, food, and personal essentials to people newly released",
	"Offering life-skills counseling and short-term mentoring relationships",
	"Helping secure housing — application fees, security deposits, and furnishings",
	"Collecting and delivering donated furniture for newly housed clients",
	"Providing emergency funds to prevent eviction or meet urgent financial needs",
	"Connecting clients to employers and navigating job applications together",
];

const impactStats = [
	{ value: "361", label: "Clients helped in 2025" },
	{ prefix: "$", value: "25,000+", label: "Contributed to the RCAN Fund in 2025" },
	{ value: "20", label: "Participating Congregations" },
	{ value: "40", label: "Active Prison Friendship Matches" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="pb-10 pt-6 md:pb-14 md:pt-8" aria-label="About RCAN">
		<div class="grid gap-10 lg:grid-cols-2 lg:items-stretch">
			<!-- Image LEFT -->
			<figure class="overflow-hidden rounded-lg shadow-lg">
				<Image
					src={heroImage}
					class="h-full min-h-80 w-full object-cover"
					alt="A circle of people placing their hands together to show shared support and community solidarity."
					width={900}
					widths={[360, 540, 720, 900]}
					sizes="(min-width: 1024px) 50vw, 100vw"
					format="webp"
					quality={60}
					loading="eager"
					priority
				/>
			</figure>

			<!-- Text + buttons RIGHT -->
			<article class="flex h-full flex-col gap-6">
				<SectionHeader
					level={1}
					heading="Returning Citizens Assistance Network"
					subheading="RCAN responds to urgent needs for returning citizens and others in the criminal justice system - all referred by the DC Public Defender Service. The network focuses on practical barriers to reentry: housing, clothing, food, employment, and ongoing personal support."
				/>
				<p class="text-base leading-7 text-text-subtle">
					In 2018, inspired by Bryan Stevenson's call to get proximate to those who are
					incarcerated, New York Avenue Presbyterian Church and Metropolitan AME Church
					partnered with the DC Public Defender Service to establish RCAN - an informal
					network of congregations committed to social justice and practical help.
				</p>
				<div class="mt-auto flex flex-wrap items-center justify-end gap-3">
					<Button href="/donate" variant="primary" size="md">Donate today</Button>
					<Button href="/how-we-help" variant="secondary" size="md">How RCAN helps</Button>
				</div>
				<p class="mt-4 text-right text-xs italic text-text-subtle" aria-hidden="true">
					"I was in prison and you came to visit me." - Matthew 25:36
				</p>
			</article>
		</div>

		<!-- Stats row below hero -->
		<div class="mt-10">
			<StatStrip stats={impactStats} layout="grid" background="subtle" accentColor="primary" hoverSwapAccent />
		</div>
	</section>

	<section aria-labelledby="assistance-heading">
		<h2 id="assistance-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">How RCAN assists</h2>
		<p class="mt-6 text-base leading-7 text-text-subtle">
			RCAN responds to urgent reentry needs through direct referrals and coordinated support from partner congregations.
			The examples below show how assistance is delivered and where people can step in to help.
		</p>

		<div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 md:items-stretch">
			<div class="flex min-h-0 flex-col md:h-full">
				<BulletList items={assistanceExamples} columns={1} />
				<div class="relative mt-8 flex-1 overflow-hidden rounded-lg md:mt-10">
					<Image
						src={gardeningCommunityImage}
						alt="Community members gardening together in a shared green space."
						class="absolute inset-0 h-full w-full object-cover"
						width={600}
						format="webp"
						quality={70}
					/>
				</div>
			</div>

			<div class="flex min-h-0 flex-col gap-4 md:h-full">
				<article class="group flex min-h-0 flex-1 gap-4 rounded-lg bg-surface-subtle px-5 py-6 md:transition-shadow md:hover:shadow-md">
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-surface-default text-brand-secondary md:transition-colors group-hover:bg-brand-secondary group-hover:text-surface-default">
						<Icon name="heart" class="h-7 w-7" />
					</div>
					<div class="flex min-h-0 flex-1 flex-col">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<p class="text-xs font-semibold uppercase tracking-widest text-brand-secondary">Donate</p>
						</div>
						<div class="mt-1">
							<h3 class="text-base font-semibold text-text-default">Give to the RCAN Fund</h3>
						</div>
						<p class="mt-2 text-sm leading-6 text-text-subtle">Every gift goes directly to urgent client needs — housing, food, emergency funds, and more.</p>
						<div class="mt-auto flex justify-end pt-4">
							<Button href="/donate" variant="secondary" size="sm">Give now &rarr;</Button>
						</div>
					</div>
				</article>
				<article class="group flex min-h-0 flex-1 gap-4 rounded-lg bg-surface-subtle px-5 py-6 md:transition-shadow md:hover:shadow-md">
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-surface-default text-brand-secondary md:transition-colors group-hover:bg-brand-secondary group-hover:text-surface-default">
						<Icon name="users" class="h-7 w-7" />
					</div>
					<div class="flex min-h-0 flex-1 flex-col">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<p class="text-xs font-semibold uppercase tracking-widest text-brand-secondary">Volunteer</p>
						</div>
						<div class="mt-1">
							<h3 class="text-base font-semibold text-text-default">Serve a returning citizen</h3>
						</div>
						<p class="mt-2 text-sm leading-6 text-text-subtle">Become a Prison Friend or respond to specific client requests through your congregation.</p>
						<div class="mt-auto flex justify-end pt-4">
							<Button href="/get-involved" variant="secondary" size="sm">Get involved &rarr;</Button>
						</div>
					</div>
				</article>
				<article class="group flex min-h-0 flex-1 gap-4 rounded-lg bg-surface-subtle px-5 py-6 md:transition-shadow md:hover:shadow-md">
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-surface-default text-brand-secondary md:transition-colors group-hover:bg-brand-secondary group-hover:text-surface-default">
						<Icon name="book-open" class="h-7 w-7" />
					</div>
					<div class="flex min-h-0 flex-1 flex-col">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<p class="text-xs font-semibold uppercase tracking-widest text-brand-secondary">Congregations</p>
						</div>
						<div class="mt-1">
							<h3 class="text-base font-semibold text-text-default">Join the network</h3>
						</div>
						<p class="mt-2 text-sm leading-6 text-text-subtle">If your congregation is in the DC, MD, or VA area, RCAN welcomes new partners committed to social justice.</p>
						<div class="mt-auto flex justify-end pt-4">
							<Button href="/get-involved" variant="secondary" size="sm">Learn how &rarr;</Button>
						</div>
					</div>
				</article>
			</div>
		</div>

		<p class="mt-10 text-xs font-semibold uppercase tracking-widest text-brand-secondary">Client story</p>
		<figure class="group mt-3 rounded-lg bg-surface-subtle px-5 py-5 motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-md">
			<blockquote class="border-l-4 border-brand-secondary pl-6 motion-safe:transition-colors motion-safe:duration-200 group-hover:border-brand-primary">
				<p class="text-base italic leading-8 text-text-default">Thank you all for your help in supporting TW and his family. All of your donations went such a long way to relieving the stress and anxiety of TW. He is safely with his grandparents that love and care for him. Their immediate burdens have been relieved thanks to the assistance of you all. I cannot express to you the joy this has brought to this family. Thank you all again so much!</p>
			</blockquote>
			<figcaption class="mt-3 text-right text-sm text-text-subtle">&mdash; PDS Lawyer</figcaption>
		</figure>
	</section>

	<section class="rounded-lg bg-surface-subtle px-6 py-8 md:px-8 md:py-10" aria-labelledby="pfp-teaser-heading" data-fade>
		<h2 id="pfp-teaser-heading" class="section-title text-base font-semibold uppercase tracking-widest text-text-subtle">Prison Friendship Project</h2>
		<p class="mt-3 text-base leading-7 text-text-subtle">
			About 4,000 people from Washington, DC are scattered across federal prisons. The Prison
			Friendship Project matches RCAN supporters with DC clients to build human connection
			across distance. RCAN provides match guidance, client background, and access to social
			workers and attorneys throughout the friendship.
		</p>
		<div class="mt-6 flex flex-wrap items-center justify-between gap-4">
			<dl class="flex gap-8">
				<div aria-label="23 new Prison Friendship matches in 2025">
					<dd class="text-2xl font-bold text-brand-secondary">23</dd>
					<dt class="mt-0.5 text-xs text-text-subtle">new matches in 2025</dt>
				</div>
				<div aria-label="40 active Prison Friendship matches">
					<dd class="text-2xl font-bold text-brand-secondary">40</dd>
					<dt class="mt-0.5 text-xs text-text-subtle">active matches</dt>
				</div>
			</dl>
			<Button href="/get-involved#prison-friendship-project" variant="primary" size="md">Become a Prison Friend</Button>
		</div>
	</section>

	<CTABlock
		variant="outline"
		heading="Stand with returning citizens."
		body="Donations fund emergency needs. Volunteers build connections. Every contribution - of any kind - makes a difference."
		primaryLabel="Donate"
		primaryHref="/donate"
		secondaryLabel="Get involved"
		secondaryHref="/get-involved"
	/>

	<script>
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		if (!reduceMotion) {
			const fadeTargets = document.querySelectorAll("[data-fade]");
			fadeTargets.forEach((target) => {
				target.classList.add("opacity-0");
			});

			const fadeObserver = new IntersectionObserver(
				(entries, observer) => {
					entries.forEach((entry) => {
						if (!entry.isIntersecting) {
							return;
						}

						entry.target.classList.remove("opacity-0");
						entry.target.classList.add("opacity-100", "transition-opacity", "duration-300");
						observer.unobserve(entry.target);
					});
				},
				{ threshold: 0.1 },
			);

			fadeTargets.forEach((target) => {
				fadeObserver.observe(target);
			});
		}
	</script>
</BaseLayout>
