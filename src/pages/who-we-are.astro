---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionTitle from "../components/SectionTitle.astro";
import CTABlock from "../components/CTABlock.astro";
import Icon from "../components/Icon.astro";
import { congregations } from "../data/congregations";

const pageTitle = "Who We Are | RCAN";
const pageDescription =
  "Meet the RCAN Board of Directors and the congregations across the Washington, DC area that power the network.";

const boardMembers = [
  { name: "Madalena Aspiras", affiliation: "Warner Memorial Presbyterian Church" },
  { name: "Theo Brown", affiliation: "New York Avenue Presbyterian Church" },
  { name: "Laura Cohen", affiliation: "Public Defender Service" },
  { name: "Quiana Harris", affiliation: "Public Defender Service" },
  { name: "Rob Hornstein", affiliation: "Public Defender Service" },
  { name: "Connie Kurihara", affiliation: "St. Columba's Episcopal Church" },
  { name: "Marcia Mendenhall", affiliation: "Emory United Methodist Church" },
  { name: "Eric Nicoll", affiliation: "Holy Trinity Catholic Church" },
  { name: "Kay Tatum", affiliation: "St. Columba's Episcopal" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section aria-labelledby="who-we-are-heading" class="border-b border-border-default pb-10 pt-2 md:pb-12">
    <PageHeader
      id="who-we-are-heading"
      eyebrow="Who We Are"
      heading="A volunteer board and a growing network of congregations"
    />
  </section>

  <!-- Board of Directors -->
  <section class="py-10" aria-labelledby="board-heading">
    <SectionTitle id="board-heading" text="Board of Directors" />
    <p class="mx-auto mt-2 max-w-2xl text-center text-sm text-text-subtle">
      Three attorneys with Public Defender Service and six representatives from RCAN member congregations.
    </p>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2" aria-label="Board of Directors">
      {
        boardMembers.map(({ name, affiliation }) => (
          <li class="flex items-baseline gap-2 rounded-lg border border-border-default bg-surface-subtle px-4 py-4">
            <span class="text-sm font-semibold text-text-default">{name},</span>
            <span class="text-xs text-text-subtle">{affiliation}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Participating Congregations -->
  <section class="border-t border-border-default py-10" aria-labelledby="congregations-heading">
    <SectionTitle id="congregations-heading" text="Participating congregations" />
    <p class="mx-auto mt-2 max-w-2xl text-center text-base leading-7 text-text-subtle">
      {congregations.length} congregations across the Washington, DC area have joined RCAN and committed
      to responding to needs as they arise.
    </p>

    <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3" aria-label="List of participating congregations">
      {
        congregations.map(({ name, url }) => (
          <li>
            {url ? (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${name} (opens in a new tab)`}
                class="group flex items-center justify-between gap-2 rounded-lg border border-border-default bg-surface-default px-4 py-3 text-sm font-medium text-text-default shadow-sm motion-safe:transition-colors motion-safe:duration-200 visited:text-neutral-600 hover:border-brand-secondary hover:bg-surface-subtle"
              >
                <span class="flex min-w-0 items-center gap-2">
                  <Icon name="landmark" size="sm" class="shrink-0 text-brand-secondary group-visited:text-neutral-400" aria-hidden="true" />
                  <span class="truncate">{name}</span>
                </span>
                <Icon
                  name="external-link"
                  size="sm"
                  class="shrink-0 opacity-0 transition-opacity group-hover:opacity-60"
                  aria-hidden="true"
                />
              </a>
            ) : (
              <div class="flex items-center gap-2 rounded-lg border border-border-default bg-surface-default px-4 py-3 text-sm font-medium text-text-default">
                <Icon name="landmark" size="sm" class="shrink-0 text-text-subtle" aria-hidden="true" />
                <span class="truncate">{name}</span>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </section>

  <CTABlock
    heading="Is your congregation ready to join RCAN?"
    body="RCAN welcomes new partner congregations across the Washington, DC area ready to respond to urgent reentry needs."
    primaryLabel="Get involved"
    primaryHref="/get-involved"
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />

</BaseLayout>
